@model Bayti.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "Accueil";
    var cRate = Model.TotalTasksToday > 0 ? (Model.CompletedTasksToday * 100 / Model.TotalTasksToday) : 0;
    var name = User.Identity?.Name?.Split('@')[0] ?? "Coloc";
    var h = DateTime.Now.Hour;
    var greet = h < 12 ? "Bonjour" : h < 18 ? "Bon après-midi" : "Bonsoir";
    string[] tips = { "🧺 Penser à faire la lessive !", "🌿 Arroser les plantes !", "🗑️ Sortir les poubelles ce soir !", "🛒 Faire les courses demain !", "✨ Maison propre = esprit sain !" };
    var tip = tips[DateTime.Now.DayOfYear % tips.Length];
}

<div class="page-wrap">

    <!-- HERO ──────────────────── -->
    <div class="hero-banner">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-orb hero-orb-3"></div>
        <div class="hero-content">
            <div>
                <div class="hero-eyebrow">🏠 Votre espace, organisé</div>
                <h1 class="hero-title">@greet, @name !</h1>
                <p class="hero-desc">
                    @if (Model.MyPendingTasks.Any())
                    {<text>Vous avez <strong>@Model.MyPendingTasks.Count()</strong> mission(s) en attente aujourd'hui.</text>}
                    else {<text>Aucune mission. Profitez de votre maison propre ✨</text>}
                </p>
                <div class="hero-tip">💡 @tip</div>
            </div>
            <div class="hero-ring-wrap">
                <svg width="120" height="120" viewBox="0 0 120 120">
                    <circle cx="60" cy="60" r="48" fill="none" stroke="rgba(255,255,255,0.18)" stroke-width="9"/>
                    <circle cx="60" cy="60" r="48" fill="none" stroke="white" stroke-width="9"
                            stroke-linecap="round"
                            stroke-dasharray="@(301 * cRate / 100) 301"
                            transform="rotate(-90 60 60)" style="transition:stroke-dasharray 1s ease;"/>
                    <text x="60" y="55" text-anchor="middle" fill="white" font-size="20" font-weight="900" font-family="'Nunito',sans-serif">@cRate%</text>
                    <text x="60" y="72" text-anchor="middle" fill="rgba(255,255,255,0.75)" font-size="11" font-family="'Plus Jakarta Sans',sans-serif">terminé</text>
                </svg>
                <div class="hero-ring-label">Aujourd'hui</div>
            </div>
        </div>
    </div>

    <!-- STATS ─────────────────── -->
    <div class="stats-row">
        <div class="stat-tile stat-coral">
            <div class="stat-tile-icon">⭐</div>
            <div>
                <div class="stat-label">Mes points</div>
                <div class="stat-val">@Model.UserPoints</div>
            </div>
        </div>
        <div class="stat-tile stat-mint">
            <div class="stat-tile-icon">🧹</div>
            <div>
                <div class="stat-label">Missions du jour</div>
                <div class="stat-val">@Model.CompletedTasksToday <span class="stat-of">/ @Model.TotalTasksToday</span></div>
            </div>
        </div>
        <div class="stat-tile stat-lavender">
            <div class="stat-tile-icon">👥</div>
            <div>
                <div class="stat-label">Membres</div>
                <div class="stat-val">@(Model.Colocation?.Members?.Count ?? 0)</div>
            </div>
        </div>
    </div>

    <!-- GRID ──────────────────── -->
    <div class="dash-grid">

        <!-- Tasks -->
        <div class="card card-p">
            <div class="section-head">
                <div>
                    <h2 class="section-title">🧹 Mes Missions</h2>
                    <p class="section-sub">Tâches en attente aujourd'hui</p>
                </div>
                <a asp-controller="Tasks" asp-action="Index" class="btn btn-ghost btn-sm">
                    Tout voir <i class="fa-solid fa-arrow-right fa-xs"></i>
                </a>
            </div>

            <div class="task-list">
                @if (!Model.MyPendingTasks.Any())
                {
                    <div class="empty-state" style="padding:30px 0;">
                        <div class="empty-state-icon">🛋️</div>
                        <h3>Tout est propre !</h3>
                        <p>Aucune mission en attente.</p>
                    </div>
                }
                @foreach (var task in Model.MyPendingTasks.Take(6))
                {
                    <div class="task-row">
                        <div class="ibox ibox-sm ibox-coral"><i class="fa-solid @(task.TaskTemplate.Category?.Icon ?? "fa-broom")"></i></div>
                        <div class="task-info">
                            <span class="task-name">@task.TaskTemplate.Title</span>
                            <span class="task-meta">
                                <span class="badge badge-coral">@(task.TaskTemplate.Category?.Name ?? "Général")</span>
                                <span class="task-time">⏰ @task.DueDate.ToString("HH:mm")</span>
                            </span>
                        </div>
                        <span class="task-pts">+@task.TaskTemplate.Points ⭐</span>
                        <form asp-controller="Tasks" asp-action="Complete" asp-route-id="@task.Id" method="post" style="margin:0">
                            <button type="submit" class="check-btn" title="Marquer comme terminée">
                                <i class="fa-solid fa-check"></i>
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <!-- Side column -->
        <div class="side-col">

            <!-- Leaderboard -->
            <div class="card card-p">
                <h2 class="section-title" style="margin-bottom:18px;">🏆 Classement</h2>
                <div class="leader-list">
                    @if (Model.Colocation != null && Model.Colocation.Members != null)
                    {
                        foreach (var (user, i) in Model.Colocation.Members.OrderByDescending(m => m.Points).Select((u, i) => (u, i)).Take(5))
                        {
                            var self = user.Email == User.Identity?.Name;
                        <div class="leader-row @(self ? "leader-self" : "")">
                            <span class="leader-pos">
                                @if (i == 0) {<text>🥇</text>}
                                else if (i == 1) {<text>🥈</text>}
                                else if (i == 2) {<text>🥉</text>}
                                else {<text>@(i+1)</text>}
                            </span>
                            <img src="@(user.AvatarUrl ?? "/images/avatars/avatar1.png")" class="leader-av" />
                            <span class="leader-name">@user.FullName.Split(' ').First()</span>
                            <span class="leader-pts">@user.Points ⭐</span>
                        </div>
                    }
                }
            </div>
            </div>

            <!-- Activity -->
            <div class="card card-p" style="margin-top: 20px;">
                <h2 class="section-title" style="margin-bottom:18px;">⚡ Activité récente</h2>
                <div class="activity-list">
                    @if (!Model.ColocationTasks.Any())
                    {
                        <p style="color:var(--ink-4); font-size:13px; text-align:center; padding: 12px 0;">Aucune activité récente</p>
                    }
                    @foreach (var t in Model.ColocationTasks.Take(7))
                    {
                        <div class="act-row">
                            <div class="act-dot"></div>
                            <div class="act-text">
                                <strong>@(t.AssignedUser?.FullName.Split(' ').First())</strong>
                                a complété <em>@t.TaskTemplate.Title</em>
                                <time>@t.CompletedAt?.ToString("HH:mm")</time>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>

</div>

<style>
/* HERO */
.hero-banner {
    background: linear-gradient(145deg, #FF6B6B 0%, #FF8E8E 35%, #FF6B9D 65%, #C44FFF 100%);
    border-radius: 24px; padding: 44px 52px;
    margin-bottom: 28px; display: flex; position: relative; overflow: hidden;
    box-shadow: 0 16px 48px rgba(255,107,107,0.35);
}
.hero-content { display: flex; justify-content: space-between; align-items: center; width: 100%; position: relative; z-index: 2; }
.hero-orb { position: absolute; border-radius: 50%; }
.hero-orb-1 { width: 280px; height: 280px; background: rgba(255,255,255,0.08); top: -90px; right: -70px; }
.hero-orb-2 { width: 180px; height: 180px; background: rgba(255,255,255,0.06); bottom: -80px; left: 200px; }
.hero-orb-3 { width: 100px; height: 100px; background: rgba(255,255,255,0.05); top: 10px; left: 50%; }
.hero-eyebrow { display: inline-flex; align-items: center; background: rgba(255,255,255,0.22); color: white; padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; letter-spacing: 0.3px; margin-bottom: 12px; backdrop-filter: blur(8px); }
.hero-title { font-family: var(--font-display); font-size: 40px; font-weight: 900; color: white; letter-spacing: -1.2px; margin-bottom: 8px; }
.hero-desc { color: rgba(255,255,255,0.88); font-size: 15px; max-width: 380px; }
.hero-desc strong { color: white; }
.hero-tip { margin-top: 14px; font-size: 13px; color: rgba(255,255,255,0.75); background: rgba(255,255,255,0.12); padding: 6px 14px; border-radius: 12px; display: inline-block; backdrop-filter: blur(4px); }
.hero-ring-wrap { display: flex; flex-direction: column; align-items: center; gap: 8px; }
.hero-ring-label { font-size: 12px; color: rgba(255,255,255,0.7); font-weight: 700; text-transform: uppercase; letter-spacing: 0.8px; }

/* STATS */
.stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-bottom: 24px; }
.stat-tile {
    border-radius: 18px; padding: 22px 24px;
    display: flex; align-items: center; gap: 16px;
    transition: var(--t-spring); cursor: default;
    border: 1px solid transparent;
    position: relative; overflow: hidden;
}
.stat-tile::before { content: ''; position: absolute; inset: 0; opacity: 0; transition: var(--t-fast); border-radius: inherit; }
.stat-tile:hover { transform: translateY(-4px); }
.stat-tile:hover::before { opacity: 1; }
.stat-coral { background: linear-gradient(135deg, #FFF2F2 0%, #FFE0E0 100%); border-color: rgba(255,107,107,0.2); box-shadow: 0 4px 20px rgba(255,107,107,0.12); }
.stat-coral:hover { box-shadow: 0 10px 30px rgba(255,107,107,0.22); }
.stat-mint  { background: linear-gradient(135deg, #E8FBF8 0%, #D0F5EE 100%); border-color: rgba(0,201,167,0.2); box-shadow: 0 4px 20px rgba(0,201,167,0.12); }
.stat-mint:hover { box-shadow: 0 10px 30px rgba(0,201,167,0.22); }
.stat-lavender { background: linear-gradient(135deg, #F3EFFE 0%, #E8DFFE 100%); border-color: rgba(167,139,250,0.2); box-shadow: 0 4px 20px rgba(167,139,250,0.12); }
.stat-lavender:hover { box-shadow: 0 10px 30px rgba(167,139,250,0.22); }
.stat-tile-icon { font-size: 32px; flex-shrink: 0; }
.stat-label { font-size: 11px; font-weight: 700; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 4px; }
.stat-val { font-family: var(--font-display); font-size: 28px; font-weight: 900; color: var(--ink); }
.stat-of { font-size: 18px; color: var(--ink-3); }

/* GRID */
.dash-grid { display: grid; grid-template-columns: 1.4fr 0.6fr; gap: 22px; }
.side-col { display: flex; flex-direction: column; }
.section-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
.section-title { font-family: var(--font-display); font-size: 18px; font-weight: 800; color: var(--ink); }
.section-sub { font-size: 13px; color: var(--ink-4); margin-top: 2px; }

/* TASKS */
.task-list { display: flex; flex-direction: column; gap: 2px; }
.task-row { display: flex; align-items: center; gap: 12px; padding: 10px 8px; border-radius: 12px; transition: var(--t-fast); }
.task-row:hover { background: var(--bg); }
.task-info { flex: 1; min-width: 0; }
.task-name { display: block; font-size: 14px; font-weight: 700; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.task-meta { display: flex; align-items: center; gap: 6px; margin-top: 3px; }
.task-time { font-size: 11px; color: var(--ink-4); font-weight: 600; }
.task-pts { font-size: 13px; font-weight: 800; color: var(--coral); white-space: nowrap; margin: 0 8px; }
.check-btn {
    width: 34px; height: 34px; border-radius: 10px;
    border: 2px solid var(--border); background: white;
    color: var(--green); font-size: 13px; cursor: pointer;
    transition: var(--t-spring); display: flex; align-items: center; justify-content: center;
}
.check-btn:hover { background: var(--green); color: white; border-color: var(--green); transform: scale(1.15) rotate(5deg); }

/* LEADERBOARD */
.leader-list { display: flex; flex-direction: column; gap: 6px; }
.leader-row { display: flex; align-items: center; gap: 10px; padding: 8px 10px; border-radius: 12px; transition: var(--t-fast); }
.leader-row:hover { background: var(--bg); }
.leader-self { background: linear-gradient(135deg, var(--coral-bg), #FFF5E0); border: 1px solid rgba(255,107,107,0.20); }
.leader-pos { width: 28px; text-align: center; font-size: 18px; flex-shrink: 0; }
.leader-av { width: 34px; height: 34px; border-radius: 10px; object-fit: cover; flex-shrink: 0; border: 2px solid var(--border); }
.leader-name { flex: 1; font-size: 13px; font-weight: 700; color: var(--ink); min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.leader-pts { font-size: 13px; font-weight: 800; color: var(--coral); white-space: nowrap; }

/* ACTIVITY */
.activity-list { display: flex; flex-direction: column; gap: 14px; }
.act-row { display: flex; gap: 10px; }
.act-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--coral); margin-top: 5px; flex-shrink: 0; box-shadow: 0 0 0 3px var(--coral-bg); }
.act-text { font-size: 13px; color: var(--ink-2); line-height: 1.5; }
.act-text em { font-style: normal; color: var(--coral); font-weight: 700; }
.act-text time { display: block; font-size: 11px; color: var(--ink-4); margin-top: 2px; }
</style>

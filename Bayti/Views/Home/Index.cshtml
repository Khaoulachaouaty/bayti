@model Bayti.Controllers.DashboardViewModel
@{
    ViewData["Title"] = "Accueil";
    var cRate = Model.TotalTasksToday > 0 ? (Model.CompletedTasksToday * 100 / Model.TotalTasksToday) : 0;
    var name = User.Identity.Name?.Split('@')[0] ?? "Coloc";
    var h = DateTime.Now.Hour;
    var greet = h < 12 ? "Bonjour" : h < 18 ? "Bon après-midi" : "Bonsoir";
}

<div class="page-wrap">

    <!-- HERO ──────────────────────────────────────────── -->
    <div class="hero-banner">
        <div class="hero-orb hero-orb-1"></div>
        <div class="hero-orb hero-orb-2"></div>
        <div class="hero-content">
            <div>
                <div class="hero-eyebrow">🏠 Votre espace, organisé</div>
                <h1 class="hero-title">@greet, @name !</h1>
                <p class="hero-desc">
                    @if (Model.MyPendingTasks.Any())
                    {<text>Vous avez <strong>@Model.MyPendingTasks.Count()</strong> mission(s) en attente aujourd'hui.</text>}
                    else {<text>Aucune mission. Profitez de votre maison propre ✨</text>}
                </p>
            </div>
            <div class="hero-ring-wrap">
                <svg width="110" height="110" viewBox="0 0 110 110">
                    <circle cx="55" cy="55" r="44" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="8"/>
                    <circle cx="55" cy="55" r="44" fill="none" stroke="rgba(255,255,255,0.9)" stroke-width="8"
                            stroke-linecap="round"
                            stroke-dasharray="@(276 * cRate / 100) 276"
                            transform="rotate(-90 55 55)"/>
                    <text x="55" y="50" text-anchor="middle" fill="white" font-size="18" font-weight="900" font-family="'Nunito',sans-serif">@cRate%</text>
                    <text x="55" y="66" text-anchor="middle" fill="rgba(255,255,255,0.75)" font-size="11" font-family="'Inter',sans-serif">terminé</text>
                </svg>
            </div>
        </div>
    </div>

    <!-- STATS ─────────────────────────────────────────── -->
    <div class="stats-row">
        <div class="stat-tile">
            <div class="ibox ibox-md ibox-coral"><i class="fa-solid fa-star"></i></div>
            <div>
                <div class="stat-label">Points totaux</div>
                <div class="stat-val">@Model.UserPoints</div>
            </div>
        </div>
        <div class="stat-tile">
            <div class="ibox ibox-md ibox-amber">🧹</div>
            <div>
                <div class="stat-label">Missions du jour</div>
                <div class="stat-val">@Model.CompletedTasksToday <span class="stat-of">/ @Model.TotalTasksToday</span></div>
            </div>
        </div>
        <div class="stat-tile">
            <div class="ibox ibox-md ibox-green"><i class="fa-solid fa-users"></i></div>
            <div>
                <div class="stat-label">Membres</div>
                <div class="stat-val">@(Model.Colocation?.Members?.Count ?? 0)</div>
            </div>
        </div>
    </div>

    <!-- GRID ──────────────────────────────────────────── -->
    <div class="dash-grid">

        <!-- Tasks ─────── -->
        <div class="card card-p">
            <div class="section-head">
                <div>
                    <h2 class="section-title">Mes Missions 🧹</h2>
                    <p class="section-sub">Tâches en attente</p>
                </div>
                <a asp-controller="Tasks" asp-action="Index" class="btn btn-ghost btn-sm">
                    Tout voir <i class="fa-solid fa-arrow-right fa-xs"></i>
                </a>
            </div>

            <div class="task-list">
                @if (!Model.MyPendingTasks.Any())
                {
                    <div class="empty-box">
                        <div class="empty-emoji">🛋️</div>
                        <strong>Tout est propre !</strong>
                        <span>Aucune mission en attente.</span>
                    </div>
                }
                @foreach (var task in Model.MyPendingTasks.Take(6))
                {
                    <div class="task-row">
                        <div class="ibox ibox-sm ibox-coral"><i class="fa-solid @(task.TaskTemplate.Category?.Icon ?? "fa-broom")"></i></div>
                        <div class="task-info">
                            <span class="task-name">@task.TaskTemplate.Title</span>
                            <span class="task-meta">
                                <span class="badge badge-coral">@(task.TaskTemplate.Category?.Name ?? "Général")</span>
                                <span class="task-time">@task.DueDate.ToString("HH:mm")</span>
                            </span>
                        </div>
                        <span class="task-pts">+@task.TaskTemplate.Points</span>
                        <form asp-controller="Tasks" asp-action="Complete" asp-route-id="@task.Id" method="post" style="margin:0">
                            <button type="submit" class="check-btn"><i class="fa-solid fa-check"></i></button>
                        </form>
                    </div>
                }
            </div>
        </div>

        <!-- Side ─────── -->
        <div class="side-col">

            <!-- Leaderboard -->
            <div class="card card-p">
                <h2 class="section-title" style="margin-bottom:16px;">Classement 🏆</h2>
                <div class="leader-list">
                    @foreach (var (user, i) in Model.Colocation.Members.OrderByDescending(m => m.Points).Select((u,i)=>(u,i)).Take(5))
                    {
                        var self = user.Email == User.Identity.Name;
                        <div class="leader-row @(self ? "leader-self" : "")">
                            <span class="leader-pos">
                                @if (i == 0) {<text>🥇</text>}
                                else if (i == 1) {<text>🥈</text>}
                                else if (i == 2) {<text>🥉</text>}
                                else {<text>@(i+1)</text>}
                            </span>
                            <img src="@(user.AvatarUrl ?? "/images/avatars/avatar1.png")" class="leader-av" />
                            <span class="leader-name">@user.FullName.Split(' ').First()</span>
                            <span class="leader-pts">@user.Points</span>
                        </div>
                    }
                </div>
            </div>

            <!-- Activity -->
            <div class="card card-p" style="margin-top: 20px;">
                <h2 class="section-title" style="margin-bottom:16px;">Activité</h2>
                <div class="activity-list">
                    @if (!Model.ColocationTasks.Any())
                    {
                        <p style="color:var(--ink-4); font-size:13px; text-align:center; padding: 12px 0;">Aucune activité récente</p>
                    }
                    @foreach (var t in Model.ColocationTasks.Take(7))
                    {
                        <div class="act-row">
                            <div class="act-dot"></div>
                            <div class="act-text">
                                <strong>@(t.AssignedUser?.FullName.Split(' ').First())</strong>
                                a complété <em>@t.TaskTemplate.Title</em>
                                <time>@t.CompletedAt?.ToString("HH:mm")</time>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>

</div>

<style>
/* HERO */
.hero-banner {
    background: var(--grad-hero);
    border-radius: var(--r-xl);
    padding: 40px 48px;
    margin-bottom: 28px;
    display: flex;
    position: relative;
    overflow: hidden;
    box-shadow: var(--shadow-coral);
}
.hero-content { display: flex; justify-content: space-between; align-items: center; width: 100%; position: relative; z-index: 2; }
.hero-orb { position: absolute; border-radius: 50%; }
.hero-orb-1 { width: 260px; height: 260px; background: rgba(255,255,255,0.08); top: -80px; right: -60px; }
.hero-orb-2 { width: 200px; height: 200px; background: rgba(255,255,255,0.06); bottom: -80px; left: 220px; }
.hero-eyebrow { display: inline-flex; align-items: center; background: rgba(255,255,255,0.22); color: white; padding: 5px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; letter-spacing: 0.3px; margin-bottom: 12px; }
.hero-title { font-family: var(--font-display); font-size: 38px; font-weight: 900; color: white; letter-spacing: -1.2px; margin-bottom: 8px; }
.hero-desc { color: rgba(255,255,255,0.88); font-size: 15px; max-width: 380px; }
.hero-desc strong { color: white; }

/* STATS */
.stats-row { display: grid; grid-template-columns: repeat(3,1fr); gap: 18px; margin-bottom: 24px; }
.stat-tile { background: var(--surface); border: 1px solid var(--border); border-radius: var(--r-lg); padding: 20px 22px; display: flex; align-items: center; gap: 16px; box-shadow: var(--shadow-xs); transition: var(--t-fast); }
.stat-tile:hover { transform: translateY(-3px); box-shadow: var(--shadow-sm); }
.stat-label { font-size: 11px; font-weight: 700; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px; }
.stat-val { font-family: var(--font-display); font-size: 24px; font-weight: 900; color: var(--ink); }
.stat-of { font-size: 16px; color: var(--ink-3); }

/* GRID */
.dash-grid { display: grid; grid-template-columns: 1.35fr 0.65fr; gap: 22px; }
.side-col { display: flex; flex-direction: column; }

.section-head { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 20px; }
.section-title { font-family: var(--font-display); font-size: 18px; font-weight: 800; color: var(--ink); }
.section-sub { font-size: 13px; color: var(--ink-4); margin-top: 2px; }

/* TASKS */
.task-list { display: flex; flex-direction: column; gap: 4px; }
.task-row { display: flex; align-items: center; gap: 12px; padding: 10px; border-radius: var(--r-sm); transition: var(--t-fast); }
.task-row:hover { background: var(--bg); }
.task-info { flex: 1; min-width: 0; }
.task-name { display: block; font-size: 14px; font-weight: 700; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.task-meta { display: flex; align-items: center; gap: 6px; margin-top: 3px; }
.task-time { font-size: 11px; color: var(--ink-4); font-weight: 600; }
.task-pts { font-size: 14px; font-weight: 900; color: var(--coral); white-space: nowrap; margin: 0 10px; }
.check-btn { width: 32px; height: 32px; border-radius: var(--r-xs); border: 1.5px solid var(--border); background: white; color: var(--green); font-size: 12px; cursor: pointer; transition: var(--t-fast); display: flex; align-items: center; justify-content: center; }
.check-btn:hover { background: var(--green); color: white; border-color: var(--green); transform: scale(1.1); }
.empty-box { text-align: center; padding: 40px 20px; color: var(--ink-3); }
.empty-emoji { font-size: 40px; margin-bottom: 10px; }
.empty-box strong { display: block; font-size: 16px; color: var(--ink-2); margin-bottom: 4px; }
.empty-box span { font-size: 13px; }

/* LEADERBOARD */
.leader-list { display: flex; flex-direction: column; gap: 6px; }
.leader-row { display: flex; align-items: center; gap: 10px; padding: 8px; border-radius: var(--r-sm); transition: var(--t-fast); }
.leader-row:hover { background: var(--bg); }
.leader-self { background: var(--coral-bg); border: 1px solid rgba(247,107,107,0.2); }
.leader-pos { width: 26px; text-align: center; font-size: 16px; flex-shrink: 0; }
.leader-av { width: 34px; height: 34px; border-radius: var(--r-xs); object-fit: cover; flex-shrink: 0; }
.leader-name { flex: 1; font-size: 13px; font-weight: 700; color: var(--ink); min-width: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.leader-pts { font-size: 13px; font-weight: 900; color: var(--coral); white-space: nowrap; }

/* ACTIVITY */
.activity-list { display: flex; flex-direction: column; gap: 14px; }
.act-row { display: flex; gap: 10px; }
.act-dot { width: 7px; height: 7px; border-radius: 50%; background: var(--coral); margin-top: 6px; flex-shrink: 0; opacity: 0.7; }
.act-text { font-size: 13px; color: var(--ink-2); line-height: 1.5; }
.act-text em { font-style: normal; color: var(--coral); font-weight: 700; }
.act-text time { display: block; font-size: 11px; color: var(--ink-4); margin-top: 2px; }
</style>

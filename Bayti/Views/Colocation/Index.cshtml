@using System.Security.Claims
@model Bayti.Models.Colocation
@{
    ViewData["Title"] = "Ma Tribu";
    var isAdmin = User.FindFirstValue("IsAdmin") == "True";
}

<div class="header-section mb-10 flex justify-between items-end relative" style="z-index: 10;">
    <div>
        <h1 class="page-title">Ma Tribu : @Model.Name 🏠</h1>
        <p class="text-muted">Partagez votre quotidien avec @Model.Members.Count membres.</p>
    </div>
    <div class="invite-code-pill">
        <span class="label">Code de la tribu</span>
        <span class="code">@Model.JoinCode</span>
    </div>
</div>

<div class="members-layout-grid">
    <!-- Members Column -->
    <div class="members-main">
        <div class="members-header-row mb-6">
            <h2 class="section-title">Classement de la semaine 🏆</h2>
        </div>
        
        <div class="members-premium-grid">
            @foreach (var member in Model.Members.OrderByDescending(m => m.Points))
            {
                <div class="member-modern-card @(member.IsAdmin ? "is-leader" : "")">
                    <div class="member-rank-badge">
                        @if (Model.Members.OrderByDescending(m => m.Points).ToList().IndexOf(member) == 0) { <i class="fa-solid fa-medal" style="color: #FBBF24;"></i> }
                        else { <span>#@(Model.Members.OrderByDescending(m => m.Points).ToList().IndexOf(member) + 1)</span> }
                    </div>
                    
                    <div class="member-card-body">
                        <div class="member-avatar-section">
                            <img src="@(member.AvatarUrl ?? "/images/avatars/avatar1.png")" alt="Avatar" />
                            @if (member.IsAdmin) { <div class="leader-crown"><i class="fa-solid fa-crown"></i></div> }
                        </div>
                        
                        <div class="member-info-section">
                            <div class="member-name">@member.FullName</div>
                            <div class="member-role-tag">@(member.IsAdmin ? "Chef de tribu" : "Membre actif")</div>
                        </div>

                        <div class="member-score-section">
                            <div class="points-value">@member.Points</div>
                            <div class="points-label">Points</div>
                        </div>
                    </div>
                    
                    <div class="member-card-footer">
                        <div class="activity-dot active"></div>
                        <span>En ligne</span>
                    </div>
                </div>
            }
        </div>

        <!-- Invite Banner -->
        <div class="invite-banner-v2 mt-12">
            <div class="banner-inner">
                <div class="banner-text">
                    <h3>Inviter un nouveau membre ?</h3>
                    <p>Donnez ce code pour rejoindre la colocation @Model.Name.</p>
                </div>
                <div class="banner-action">
                    <div class="code-box">@Model.JoinCode</div>
                    <button onclick="copyInviteCode()" class="btn-copy-v2">Copier</button>
                </div>
            </div>
            <div class="banner-decoration">
                <i class="fa-solid fa-users-rays"></i>
            </div>
        </div>
    </div>

    <!-- Sidebar Info Column -->
    <div class="members-sidebar">
        <div class="card premium-settings-card">
            <h3 class="section-title-sm mb-6">Gestion de la Tribu</h3>
            
            <div class="setting-item">
                <label>Mode d'affectation</label>
                @if (isAdmin) {
                    <form asp-action="UpdateAssignmentMode" method="post">
                        <select name="assignmentMode" class="premium-select" onchange="this.form.submit()">
                            <option value="Auto" selected="@(Model.AssignmentMode == "Auto")">⚡ Automatique</option>
                            <option value="Participatif" selected="@(Model.AssignmentMode == "Participatif")">🙋 Participatif</option>
                            <option value="Manuel" selected="@(Model.AssignmentMode == "Manuel")">👑 Manuel</option>
                        </select>
                    </form>
                } else {
                    <div class="static-value">@(Model.AssignmentMode)</div>
                }
            </div>

            <div class="danger-section mt-10">
                @if (isAdmin) {
                    <button onclick="openDangerModal('delete')" class="btn-danger-glass">
                        <i class="fa-solid fa-skull-crossbones mr-2"></i> Dissoudre la tribu
                    </button>
                } else {
                    <button onclick="openDangerModal('leave')" class="btn-danger-glass">
                        <i class="fa-solid fa-door-open mr-2"></i> Quitter la tribu
                    </button>
                }
            </div>
        </div>
    </div>
</div>

<!-- Danger Modal with Name Verification -->
<div id="dangerModal" class="modal-overlay">
    <div class="modal-container danger-container">
        <div class="modal-header">
            <div class="danger-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <h2 class="modal-title">Attention</h2>
        </div>
        <div class="modal-body">
            <p id="dangerModalText">Action critique détectée.</p>
            <div class="verification-box mt-6">
                <p>Pour confirmer, tapez le nom de la colocation :</p>
                <div class="target-name">@Model.Name</div>
                <input type="text" id="confirmNameInput" class="form-control-premium mt-4" placeholder="Saisir ici..." />
            </div>
        </div>
        <div class="modal-footer">
            <button onclick="closeDangerModal()" class="btn btn-outline-glass">Annuler</button>
            <form id="dangerForm" method="post" class="flex-1">
                <button type="submit" id="confirmDangerBtn" class="btn btn-danger-solid w-full" disabled>Confirmer l'action</button>
            </form>
        </div>
    </div>
</div>

<style>
    .invite-code-pill { background: white; padding: 6px 16px; border-radius: 100px; display: flex; align-items: center; gap: 12px; border: 1px solid var(--color-border); box-shadow: var(--shadow-sm); }
    .invite-code-pill .label { font-size: 10px; font-weight: 800; color: var(--color-text-muted); text-transform: uppercase; letter-spacing: 1px; }
    .invite-code-pill .code { font-size: 16px; font-weight: 900; color: var(--color-primary); letter-spacing: 1px; }

    .members-layout-grid { display: grid; grid-template-columns: 1fr 320px; gap: 40px; }
    .members-premium-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
    
    .member-modern-card { background: white; border-radius: 36px; padding: 24px; border: 1px solid var(--color-border); position: relative; transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275); }
    .member-modern-card:hover { transform: translateY(-10px); border-color: var(--color-primary); box-shadow: 0 20px 40px rgba(0,0,0,0.05); }
    .member-modern-card.is-leader { border-width: 2px; border-color: #FBBF24; box-shadow: 0 10px 25px rgba(251, 191, 36, 0.1); }
    
    .member-rank-badge { position: absolute; top: 20px; right: 24px; font-size: 14px; font-weight: 900; color: #94A3B8; }
    
    .member-card-body { display: flex; align-items: center; gap: 20px; margin-bottom: 20px; }
    .member-avatar-section { position: relative; }
    .member-avatar-section img { width: 70px; height: 70px; border-radius: 24px; object-fit: cover; border: 3px solid white; box-shadow: 0 8px 15px rgba(0,0,0,0.08); }
    .leader-crown { position: absolute; top: -10px; left: -10px; width: 28px; height: 28px; background: #FBBF24; color: white; border-radius: 10px; display: flex; align-items: center; justify-content: center; font-size: 14px; border: 2px solid white; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }

    .member-name { font-size: 18px; font-weight: 850; color: var(--color-text-primary); margin-bottom: 2px; }
    .member-role-tag { font-size: 11px; font-weight: 700; color: #64748B; background: #F1F5F9; padding: 2px 10px; border-radius: 8px; display: inline-block; }
    
    .member-score-section { margin-left: auto; text-align: center; }
    .points-value { font-size: 24px; font-weight: 900; color: var(--color-primary); line-height: 1; }
    .points-label { font-size: 10px; font-weight: 800; color: var(--color-text-muted); text-transform: uppercase; }

    .member-card-footer { display: flex; align-items: center; gap: 8px; font-size: 11px; font-weight: 700; color: #64748B; border-top: 1px solid #F1F5F9; padding-top: 16px; }
    .activity-dot { width: 8px; height: 8px; border-radius: 50%; }
    .activity-dot.active { background: #10B981; box-shadow: 0 0 8px #10B981; }

    .invite-banner-v2 { background: var(--gradient-primary); border-radius: 40px; padding: 40px; color: white; position: relative; overflow: hidden; }
    .banner-inner { position: relative; z-index: 2; display: flex; justify-content: space-between; align-items: center; }
    .banner-text h3 { font-size: 24px; font-weight: 850; margin-bottom: 4px; }
    .banner-text p { font-size: 14px; opacity: 0.9; }
    
    .banner-action { display: flex; align-items: center; gap: 12px; }
    .code-box { background: rgba(255,255,255,0.2); border: 1px solid rgba(255,255,255,0.4); padding: 12px 24px; border-radius: 16px; font-size: 24px; font-weight: 900; letter-spacing: 2px; }
    .btn-copy-v2 { background: white; color: var(--color-primary); border: none; padding: 12px 24px; border-radius: 16px; font-weight: 850; cursor: pointer; transition: 0.3s; }
    .btn-copy-v2:hover { transform: scale(1.05); }
    .banner-decoration { position: absolute; right: -20px; top: -20px; font-size: 120px; opacity: 0.1; transform: rotate(-15deg); }

    .premium-settings-card { background: white; border-radius: 36px; padding: 32px; border: 1px solid var(--color-border); }
    .premium-select { width: 100%; padding: 14px; border-radius: 16px; border: 1px solid #E2E8F0; background: #F8FAFC; font-weight: 800; color: var(--color-text-primary); outline: none; }
    .btn-danger-glass { width: 100%; padding: 14px; border-radius: 16px; background: #FFF1F2; color: #E11D48; border: 1px solid #FECDD3; font-weight: 850; font-size: 13px; cursor: pointer; transition: 0.3s; }
    .btn-danger-glass:hover { background: #E11D48; color: white; }

    /* Modal Styling */
    .danger-container { max-width: 450px; text-align: center; }
    .danger-icon { width: 80px; height: 80px; background: #FEE2E2; color: #DC2626; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 32px; margin: 0 auto 20px; }
    .target-name { font-size: 20px; font-weight: 900; color: var(--color-text-primary); margin: 12px 0; padding: 10px; background: #F8FAFC; border-radius: 12px; }
    .form-control-premium { width: 100%; padding: 16px; border-radius: 16px; border: 2px solid #E2E8F0; text-align: center; font-weight: 800; font-size: 18px; outline: none; }
    .form-control-premium:focus { border-color: #DC2626; }
    .btn-danger-solid { background: #DC2626; color: white; border: none; padding: 16px; border-radius: 16px; font-weight: 850; cursor: pointer; }
    .btn-danger-solid:disabled { opacity: 0.3; cursor: not-allowed; }
</style>

<script>
    function copyInviteCode() {
        const code = "@Model.JoinCode";
        navigator.clipboard.writeText(code);
        alert("Code copié dans le presse-papier !");
    }

    const colocationName = "@Model.Name";
    
    function openDangerModal(action) {
        const modal = document.getElementById('dangerModal');
        const text = document.getElementById('dangerModalText');
        const form = document.getElementById('dangerForm');
        
        if (action === 'delete') {
            text.innerText = "Vous allez dissoudre la tribu définitivement. Cette action effacera toutes les tâches, points et récompenses.";
            form.action = "@Url.Action("Delete", "Colocation")";
        } else {
            text.innerText = "Vous allez quitter cette tribu. Vous perdrez l'accès à cet espace de vie partagé.";
            form.action = "@Url.Action("Leave", "Colocation")";
        }
        
        modal.style.display = 'flex';
        setTimeout(() => modal.classList.add('active'), 10);
    }

    function closeDangerModal() {
        const modal = document.getElementById('dangerModal');
        modal.classList.remove('active');
        setTimeout(() => modal.style.display = 'none', 300);
    }

    document.getElementById('confirmNameInput').addEventListener('input', function(e) {
        const btn = document.getElementById('confirmDangerBtn');
        if (e.target.value === colocationName) {
            btn.disabled = false;
        } else {
            btn.disabled = true;
        }
    });
</script>

@{
    ViewData["Title"] = "Configuration de votre colocation";
}

<div class="text-center mb-12">
    <h1 class="mb-4">Bienvenue sur Bayti !</h1>
    <p class="text-muted">Pour commencer, créez votre propre colocation ou rejoignez-en une existante.</p>
</div>

<div class="grid-2">
    <!-- Créer une colocation -->
    <div class="card" style="display: flex; flex-direction: column; justify-content: space-between;">
        <div>
            <div style="width: 56px; height: 56px; background: var(--color-primary-bg); color: var(--color-primary); border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: var(--space-6);">
                <i class="fa-solid fa-plus"></i>
            </div>
            <h2 class="mb-4">Créer une colocation</h2>
            <p class="text-muted mb-8">Devenez l'administrateur et gérez les membres, les tâches et les récompenses de votre foyer.</p>
        </div>

        <form asp-action="Create" method="post">
            <div class="form-group">
                <label class="form-label">Nom de la colocation</label>
                <input name="name" class="form-control" placeholder="Ex: Les Lauriers, Appart 302..." required />
            </div>
            <button type="submit" class="btn btn-primary w-100">
                Créer ma colocation
            </button>
        </form>
    </div>

    <!-- Rejoindre une colocation -->
    <div class="card" style="display: flex; flex-direction: column; justify-content: space-between;">
        <div>
            <div style="width: 56px; height: 56px; background: var(--color-accent-bg); color: var(--color-accent); border-radius: var(--radius-lg); display: flex; align-items: center; justify-content: center; font-size: 24px; margin-bottom: var(--space-6);">
                <i class="fa-solid fa-key"></i>
            </div>
            <h2 class="mb-4">Rejoindre une colocation</h2>
            <p class="text-muted mb-8">Saisissez le code unique partagé par votre administrateur pour rejoindre vos colocataires.</p>
        </div>

        <form asp-action="Join" method="post">
            <div class="form-group">
                <label class="form-label">Code d'invitation</label>
                <input name="code" class="form-control" placeholder="ABC123" style="text-transform: uppercase; letter-spacing: 2px; text-align: center; font-weight: 700; font-size: var(--text-xl);" required />
            </div>
            <button type="submit" class="btn btn-outline w-100">
                Rejoindre le groupe
            </button>
        </form>
    </div>
</div>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-8">
        <i class="fa-solid fa-triangle-exclamation"></i>
        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <span>@error.ErrorMessage</span>
        }
    </div>
}

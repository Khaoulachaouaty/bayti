@{
    ViewData["Title"] = "Configuration de votre foyer";
}

<div class="page-wrap">
    <div class="setup-hero">
        <div class="setup-hero-inner">
            <h1 class="setup-title">🏡 Bienvenue sur Bayti</h1>
            <p class="setup-subtitle">La plateforme qui rend le ménage (enfin) amusant et organisé !</p>
        </div>
    </div>

    <div class="setup-grid">
        <!-- Créer une colocation -->
        <div class="setup-card setup-card-create">
            <div class="sc-header">
                <div class="sc-icon"><i class="fa-solid fa-house-chimney-medical"></i></div>
                <h2 class="sc-title">Lancer une tribu</h2>
                <p class="sc-text">Devenez l'administrateur et gérez les missions et récompenses de votre foyer.</p>
            </div>

            <form asp-action="Create" method="post" class="sc-form">
                <div class="form-group-premium">
                    <label class="form-label-premium">Nom de la colocation</label>
                    <input name="name" class="input-premium" placeholder="Ex: Les Lauriers, Appart 302..." required />
                </div>
                <button type="submit" class="btn btn-coral w-full py-4">
                    Créer ma tribu <i class="fa-solid fa-arrow-right ml-2"></i>
                </button>
            </form>
        </div>

        <!-- Rejoindre une colocation -->
        <div class="setup-card setup-card-join">
            <div class="sc-header">
                <div class="sc-icon"><i class="fa-solid fa-key"></i></div>
                <h2 class="sc-title">Rejoindre des amis</h2>
                <p class="sc-text">Saisissez le code unique partagé par votre administrateur pour rejoindre le groupe.</p>
            </div>

            <form asp-action="Join" method="post" class="sc-form">
                <div class="form-group-premium">
                    <label class="form-label-premium">Code d'invitation</label>
                    <input name="code" class="input-premium text-center font-display" placeholder="ABC123" 
                           style="text-transform: uppercase; letter-spacing: 4px; font-weight: 900; font-size: 20px;" required />
                </div>
                <button type="submit" class="btn btn-mint w-full py-4">
                    Rejoindre l'équipe <i class="fa-solid fa-people-group ml-2"></i>
                </button>
            </form>
        </div>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="alert alert-danger mt-8" style="max-width: 800px; margin-left: auto; margin-right: auto;">
            <i class="fa-solid fa-triangle-exclamation mr-2"></i>
            <div>
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <p>@error.ErrorMessage</p>
                }
            </div>
        </div>
    }
</div>

<style>
.setup-hero { text-align: center; margin-bottom: 48px; padding: 40px 0; }
.setup-title { font-family: var(--font-display); font-size: 42px; font-weight: 900; color: var(--ink); letter-spacing: -1px; margin-bottom: 12px; }
.setup-subtitle { font-size: 18px; color: var(--ink-3); max-width: 600px; margin: 0 auto; }

.setup-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(380px, 1fr)); gap: 32px; max-width: 1000px; margin: 0 auto; }
@@media (max-width: 850px) { .setup-grid { grid-template-columns: 1fr; } }

.setup-card {
    background: var(--surface); border: 1.5px solid var(--border); border-radius: 32px;
    padding: 44px; display: flex; flex-direction: column; justify-content: space-between;
    transition: var(--t-spring); box-shadow: var(--shadow-sm); position: relative; overflow: hidden;
}
.setup-card:hover { transform: translateY(-10px); box-shadow: var(--shadow-lg); border-color: var(--coral); }
.setup-card-join:hover { border-color: var(--mint); }

.sc-header { position: relative; z-index: 2; margin-bottom: 32px; }
.sc-icon { width: 64px; height: 64px; border-radius: 20px; display: flex; align-items: center; justify-content: center; font-size: 28px; margin-bottom: 24px; }

.setup-card-create .sc-icon { background: var(--coral-bg); color: var(--coral); }
.setup-card-join .sc-icon { background: var(--mint-bg); color: var(--mint); }

.sc-title { font-family: var(--font-display); font-size: 24px; font-weight: 900; color: var(--ink); margin-bottom: 12px; }
.sc-text { font-size: 15px; color: var(--ink-3); line-height: 1.6; }

.sc-form { position: relative; z-index: 2; }
</style>

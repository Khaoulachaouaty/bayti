@model IEnumerable<Bayti.Models.Category>
@using System.Security.Claims
@{
    ViewData["Title"] = "Domaines d'action";
    var isAdmin = User.FindFirstValue("IsAdmin") == "True";
}

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px; margin-bottom:32px;">
        <div>
            <h1 class="page-title">🏷️ Domaines & Catégories</h1>
            <p style="font-size:14px; color:var(--ink-3); margin-top:4px;">Structurez les tâches de votre foyer par thématiques.</p>
        </div>
        @if (isAdmin) {
            <a asp-action="Create" class="btn btn-coral">
                <i class="fa-solid fa-plus"></i> Nouveau domaine
            </a>
        }
    </div>

    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">🏷️</div>
            <h3>Aucune catégorie</h3>
            <p>Commencez par créer un domaine (ex: Cuisine, Salon, Jardin).</p>
        </div>
    } else {
        <div class="cat-grid">
            @foreach (var item in Model) {
                <div class="cat-card">
                    <div class="cat-card-inner">
                        <div class="cat-header">
                            <div class="cat-icon-box">
                                @if (item.Icon != null && item.Icon.StartsWith("fa-")) {
                                    <i class="fa-solid @item.Icon"></i>
                                } else {
                                    <span>@(item.Icon ?? "✨")</span>
                                }
                            </div>
                            <div class="cat-stats">
                                <span class="cat-count">@(item.TaskTemplates?.Count ?? 0)</span>
                                <span class="cat-count-label">missions</span>
                            </div>
                        </div>
                        
                        <div class="cat-info">
                            <h3 class="cat-name">@item.Name</h3>
                            <p class="cat-desc">@(string.IsNullOrEmpty(item.Description) ? "Gestion et organisation des tâches quotidiennes." : item.Description)</p>
                        </div>

                        @if (isAdmin) {
                            <div class="cat-actions">
                                <a asp-action="Edit" asp-route-id="@item.Id" class="cat-action-btn cat-edit" title="Modifier">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                                <button type="button" onclick="openDangerModal('@Url.Action("Delete", "Categories", new { id = item.Id })', 'Supprimer le domaine \'@item.Name\' ?')" class="cat-action-btn cat-delete" title="Supprimer">
                                    <i class="fa-solid fa-trash-can"></i>
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }

</div>

<!-- Danger Modal -->
<div id="dangerModal" class="modal-overlay" style="display:none;">
    <div class="modal-box" style="max-width: 400px; text-align: center;">
        <div class="modal-icon" style="background:var(--red-bg); color:var(--red); margin: 0 auto 16px;"><i class="fa-solid fa-trash-can"></i></div>
        <h2 class="modal-title" style="font-size: 20px;">Confirmation</h2>
        <p id="dangerModalText" class="mb-6" style="color:var(--ink-3); font-size:14px;"></p>
        
        <div class="modal-btns">
            <button type="button" class="btn btn-ghost" style="flex:1" onclick="closeDangerModal()">Annuler</button>
            <form id="dangerForm" method="post" style="flex:1">
                <button type="submit" class="btn btn-danger w-full">Supprimer</button>
            </form>
        </div>
    </div>
</div>

<script>
function openDangerModal(actionUrl, textContent) {
    document.getElementById('dangerModalText').innerText = textContent;
    document.getElementById('dangerForm').action = actionUrl;
    document.getElementById('dangerModal').style.display = 'flex';
}
function closeDangerModal() {
    document.getElementById('dangerModal').style.display = 'none';
}
window.addEventListener('click', (e) => {
    if (e.target.id === 'dangerModal') closeDangerModal();
});
</script>

<style>
.cat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 24px;
}

.cat-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 28px;
    padding: 24px;
    transition: var(--t-spring);
    position: relative;
    box-shadow: var(--shadow-xs);
    overflow: hidden;
}

.cat-card::before {
    content: '';
    position: absolute;
    top: -20px; right: -20px;
    width: 100px; height: 100px;
    background: var(--coral-bg);
    border-radius: 50%;
    z-index: 0;
    transition: var(--t-base);
    opacity: 0.5;
}

.cat-card:hover {
    transform: translateY(-8px);
    border-color: var(--coral);
    box-shadow: 0 20px 40px rgba(255, 107, 107, 0.12);
}

.cat-card:hover::before {
    transform: scale(1.5);
    background: var(--coral-light);
    opacity: 0.2;
}

.cat-card-inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    height: 100%;
}

.cat-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 20px;
}

.cat-icon-box {
    width: 54px; height: 54px;
    background: var(--coral-bg);
    color: var(--coral);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    border: 1.5px solid rgba(255, 107, 107, 0.15);
    transition: var(--t-base);
}

.cat-card:hover .cat-icon-box {
    background: var(--coral);
    color: white;
    transform: rotate(-5deg) scale(1.1);
}

.cat-stats {
    text-align: right;
    display: flex;
    flex-direction: column;
}

.cat-count {
    font-family: var(--font-display);
    font-size: 20px;
    font-weight: 900;
    color: var(--ink);
    line-height: 1;
}

.cat-count-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.cat-info {
    flex: 1;
}

.cat-name {
    font-family: var(--font-display);
    font-size: 19px;
    font-weight: 850;
    color: var(--ink);
    margin-bottom: 8px;
}

.cat-desc {
    font-size: 13.5px;
    color: var(--ink-3);
    line-height: 1.5;
    margin-bottom: 20px;
}

.cat-actions {
    display: flex;
    gap: 10px;
    margin-top: auto;
    padding-top: 16px;
    border-top: 1px solid var(--border);
}

.cat-action-btn {
    flex: 1;
    height: 40px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1.5px solid var(--border);
    background: var(--bg-2);
    color: var(--ink-3);
    transition: var(--t-fast);
    cursor: pointer;
    font-size: 14px;
    text-decoration: none;
}

.cat-edit:hover {
    background: var(--blue-bg);
    color: var(--blue);
    border-color: rgba(74, 144, 226, 0.3);
    transform: translateY(-2px);
}

.cat-delete:hover {
    background: var(--red-bg);
    color: var(--red);
    border-color: rgba(255, 107, 107, 0.3);
    transform: translateY(-2px);
}
</style>

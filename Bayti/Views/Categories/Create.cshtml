@model Bayti.Models.Category
@{
    ViewData["Title"] = "Nouvelle catégorie";
}

<div class="page-wrap">
    <div class="form-container-compact">
        <div class="form-header">
            <a asp-action="Index" class="btn-back"><i class="fa-solid fa-chevron-left"></i></a>
            <div>
                <h1 class="form-title">✨ Créer un domaine</h1>
                <p class="form-subtitle">Définissez une nouvelle thématique pour vos missions.</p>
            </div>
        </div>

        <div class="card card-p">
            <form asp-action="Create" method="post">
                <div class="form-group-premium">
                    <label asp-for="Name" class="form-label-premium">Nom du domaine</label>
                    <input asp-for="Name" class="input-premium" placeholder="Ex: Cuisine, Jardin, Salon..." required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group-premium">
                    <label asp-for="Description" class="form-label-premium">Description (optionnel)</label>
                    <textarea asp-for="Description" class="input-premium" rows="3" placeholder="De quoi s'agit-il ?"></textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group-premium">
                    <label class="form-label-premium">Icône ou Emoji</label>
                    <input asp-for="Icon" id="icon-input" class="input-premium mb-4" placeholder="Saisissez un emoji ou une classe FontAwesome" required />
                    
                    <div class="emoji-selector-grid">
                        @foreach (var emoji in new[] { 
                            "🧹", "🧽", "🧼", "🪠", "🗑️", "🧴", "🧤", "🍽️", "🍳", "🛒", "🍎", "🍷", "🧺", "👕", "👗", "🛋️", "🛏️", "🛁", "🚿", "🚽", "🔨", "🛠️", "💡", "🔌", "🌱", "🪴", "🐾", "🐶", "🐱", "💰", "📄", "🔑", "📦", "🗓️", "🚗", "🚲", "🌿"
                        })
                        {
                            <div class="emoji-pick" onclick="selectIcon('@emoji')">
                                @emoji
                            </div>
                        }
                    </div>
                    <div class="hint-box mt-3">
                        <i class="fa-solid fa-circle-info"></i>
                        <span>Utilisez des classes FontAwesome comme <code>fa-broom</code> pour des icônes vectorielles.</span>
                    </div>
                </div>

                <div class="form-actions mt-8">
                    <button type="submit" class="btn btn-mint w-full py-4">
                        <i class="fa-solid fa-check mr-2"></i> Créer le domaine
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.form-container-compact { max-width: 600px; margin: 0 auto; }
.form-header { display: flex; align-items: center; gap: 20px; margin-bottom: 32px; }
.btn-back { width: 44px; height: 44px; border-radius: 14px; background: var(--surface); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--ink-2); transition: var(--t-fast); }
.btn-back:hover { background: var(--bg-2); transform: translateX(-4px); }
.form-title { font-family: var(--font-display); font-size: 28px; font-weight: 900; color: var(--ink); }
.form-subtitle { font-size: 14px; color: var(--ink-3); margin-top: 4px; }

.emoji-selector-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(44px, 1fr));
    gap: 8px;
    background: var(--bg-2);
    padding: 16px;
    border-radius: 18px;
    border: 1.5px solid var(--border);
    max-height: 200px;
    overflow-y: auto;
}

.emoji-pick {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    border-radius: 10px;
    transition: var(--t-fast);
    background: var(--surface);
}

.emoji-pick:hover {
    transform: scale(1.15);
    background: var(--mint-bg);
}

.emoji-pick.active-pick {
    background: var(--mint);
    color: white;
    box-shadow: var(--shadow-mint-sm);
}

.hint-box {
    display: flex;
    gap: 10px;
    align-items: center;
    background: #F0F9FF;
    padding: 12px 16px;
    border-radius: 12px;
    color: #0369A1;
    font-size: 12px;
    font-weight: 600;
}
</style>

@section Scripts {
    <script>
        function selectIcon(icon) {
            document.getElementById('icon-input').value = icon;
            document.querySelectorAll('.emoji-pick').forEach(el => el.classList.remove('active-pick'));
            event.currentTarget.classList.add('active-pick');
        }
    </script>
}

@model Bayti.Models.Category
@{
    ViewData["Title"] = "Modifier la catégorie";
}

<div class="page-wrap">
    <div class="form-container-compact">
        <div class="form-header">
            <a asp-action="Index" class="btn-back"><i class="fa-solid fa-chevron-left"></i></a>
            <div>
                <h1 class="form-title">✏️ Modifier le domaine</h1>
                <p class="form-subtitle">Mettez à jour les informations de <strong>@Model.Name</strong>.</p>
            </div>
        </div>

        <div class="card card-p">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="form-group-premium">
                    <label asp-for="Name" class="form-label-premium">Nom du domaine</label>
                    <input asp-for="Name" class="input-premium" placeholder="Ex: Cuisine, Jardin..." required />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="form-group-premium">
                    <label asp-for="Description" class="form-label-premium">Description</label>
                    <textarea asp-for="Description" class="input-premium" rows="3" placeholder="De quoi s'agit-il ?">@Model.Description</textarea>
                    <span asp-validation-for="Description" class="text-danger"></span>
                </div>

                <div class="form-group-premium">
                    <label class="form-label-premium">Icône ou Emoji</label>
                    <div class="flex gap-4 items-center mb-4">
                        <div id="icon-preview" class="icon-preview-box">
                            @if (Model.Icon != null && Model.Icon.StartsWith("fa-")) {
                                <i class="fa-solid @Model.Icon"></i>
                            } else {
                                <span>@(Model.Icon ?? "🏷️")</span>
                            }
                        </div>
                        <input asp-for="Icon" id="icon-input" class="input-premium" placeholder="Emoji ou fa-broom" required oninput="updatePreview(this.value)" />
                    </div>
                    
                    <div class="emoji-selector-grid">
                        @foreach (var emoji in new[] { 
                            "🧹", "🧽", "🧼", "🪠", "🗑️", "🧴", "🧤", "🍽️", "🍳", "🛒", "🍎", "🍷", "🧺", "👕", "👗", "🛋️", "🛏️", "🛁", "🚿", "🚽", "🔨", "🛠️", "💡", "🔌", "🌱", "🪴", "🐾", "🐶", "🐱", "💰", "📄", "🔑", "📦", "🗓️", "🚗", "🚲", "🌿"
                        })
                        {
                            <div class="emoji-pick @(Model.Icon == emoji ? "active-pick" : "")" onclick="selectIcon('@emoji')">
                                @emoji
                            </div>
                        }
                    </div>
                </div>

                <div class="form-actions mt-8">
                    <button type="submit" class="btn btn-mint w-full py-4">
                        <i class="fa-solid fa-save mr-2"></i> Enregistrer les modifications
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
.form-container-compact { max-width: 600px; margin: 0 auto; }
.form-header { display: flex; align-items: center; gap: 20px; margin-bottom: 32px; }
.btn-back { width: 44px; height: 44px; border-radius: 14px; background: var(--surface); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--ink-2); transition: var(--t-fast); }
.btn-back:hover { background: var(--bg-2); transform: translateX(-4px); }
.form-title { font-family: var(--font-display); font-size: 28px; font-weight: 900; color: var(--ink); }
.form-subtitle { font-size: 14px; color: var(--ink-3); margin-top: 4px; }

.icon-preview-box {
    width: 56px; height: 56px;
    background: var(--mint-bg);
    color: var(--mint);
    border-radius: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    flex-shrink: 0;
    border: 1.5px solid rgba(0, 201, 167, 0.15);
}

.emoji-selector-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(44px, 1fr));
    gap: 8px;
    background: var(--bg-2);
    padding: 16px;
    border-radius: 18px;
    border: 1.5px solid var(--border);
    max-height: 200px;
    overflow-y: auto;
}

.emoji-pick {
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 20px;
    cursor: pointer;
    border-radius: 10px;
    transition: var(--t-fast);
    background: var(--surface);
}

.emoji-pick:hover {
    transform: scale(1.15);
    background: var(--mint-bg);
}

.emoji-pick.active-pick {
    background: var(--mint);
    color: white;
    box-shadow: var(--shadow-mint-sm);
}
</style>

@section Scripts {
    <script>
        function selectIcon(icon) {
            const input = document.getElementById('icon-input');
            input.value = icon;
            updatePreview(icon);
            document.querySelectorAll('.emoji-pick').forEach(el => el.classList.remove('active-pick'));
            event.currentTarget.classList.add('active-pick');
        }

        function updatePreview(val) {
            const preview = document.getElementById('icon-preview');
            if (val.startsWith('fa-')) {
                preview.innerHTML = `<i class="fa-solid ${val}"></i>`;
            } else {
                preview.innerHTML = `<span>${val || '🏷️'}</span>`;
            }
        }
    </script>
}

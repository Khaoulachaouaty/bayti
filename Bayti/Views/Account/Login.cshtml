@model Bayti.ViewModels.LoginViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Connexion – Bayti</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        body { min-height: 100vh; background: var(--bg); font-family: var(--font-body); display: grid; place-items: center; padding: 20px; }

        .auth-shell {
            display: grid;
            grid-template-columns: 1fr 1fr;
            width: 100%;
            max-width: 900px;
            border-radius: var(--r-xl);
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

        /* LEFT PANEL */
        .auth-left {
            background: var(--grad-hero);
            padding: 56px 48px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            position: relative;
            overflow: hidden;
        }
        .auth-left::before { content:''; position:absolute; width:300px; height:300px; background:rgba(255,255,255,0.08); border-radius:50%; top:-100px; right:-100px; }
        .auth-left::after  { content:''; position:absolute; width:220px; height:220px; background:rgba(255,255,255,0.06); border-radius:50%; bottom:-80px; left:-40px; }

        .al-logo { font-family: var(--font-display); font-size: 30px; font-weight: 900; color: white; letter-spacing: -1px; position:relative;z-index:1; }
        .al-logo small { display:block; font-size:13px; font-weight:500; opacity:0.75; margin-top:2px; letter-spacing:0; }

        .al-features { display:flex; flex-direction:column; gap:20px; position:relative;z-index:1; }
        .al-feat { display:flex; align-items:center; gap:14px; }
        .al-feat-icon { width:42px; height:42px; background:rgba(255,255,255,0.2); border-radius:var(--r-sm); display:flex; align-items:center; justify-content:center; font-size:20px; flex-shrink:0; }
        .al-feat-text strong { display:block; font-size:14px; font-weight:700; color:white; }
        .al-feat-text span { font-size:12px; color:rgba(255,255,255,0.75); }

        /* RIGHT PANEL */
        .auth-right { background: var(--surface); padding: 56px 52px; display:flex; flex-direction:column; justify-content:center; }
        .auth-title { font-family:var(--font-display); font-size:26px; font-weight:900; color:var(--ink); letter-spacing:-0.5px; margin-bottom:6px; }
        .auth-sub { font-size:14px; color:var(--ink-3); margin-bottom:32px; }

        .form-group { margin-bottom:18px; }
        .form-lbl { display:block; font-size:11px; font-weight:800; color:var(--ink-3); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:8px; }
        .form-inp { width:100%; padding:12px 16px; background:var(--bg-2); border:1.5px solid var(--border); border-radius:var(--r-sm); font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--ink); transition:var(--t-fast); }
        .form-inp:focus { outline:none; background:var(--surface); border-color:var(--coral); box-shadow:var(--coral-glow); }
        .form-inp::placeholder { color:var(--ink-4); }

        .auth-opts { display:flex; justify-content:space-between; align-items:center; margin-bottom:24px; font-size:13px; font-weight:600; }
        .remember { display:flex; align-items:center; gap:8px; color:var(--ink-3); cursor:pointer; }
        .remember input { width:16px; height:16px; accent-color:var(--coral); }
        .forgot { color:var(--coral); text-decoration:none; }
        .forgot:hover { text-decoration:underline; }

        .btn-submit { width:100%; padding:14px; background:var(--grad-coral); color:white; border:none; border-radius:var(--r-md); font-family:var(--font-display); font-size:16px; font-weight:800; cursor:pointer; transition:var(--t-spring); box-shadow:var(--shadow-coral-sm); }
        .btn-submit:hover { transform:translateY(-2px); box-shadow:var(--shadow-coral); }

        .auth-foot { margin-top:20px; text-align:center; font-size:14px; color:var(--ink-3); font-weight:600; }
        .auth-foot a { color:var(--coral); font-weight:800; }
    </style>
</head>
<body>
    <div class="auth-shell">

        <div class="auth-left">
            <div class="al-logo">
                🏠 Bayti
                <small>Gestion de colocation</small>
            </div>
            <div class="al-features">
                <div class="al-feat">
                    <div class="al-feat-icon">🧹</div>
                    <div class="al-feat-text">
                        <strong>Missions de ménage</strong>
                        <span>Attribuez et suivez chaque tâche</span>
                    </div>
                </div>
                <div class="al-feat">
                    <div class="al-feat-icon">⭐</div>
                    <div class="al-feat-text">
                        <strong>Points & Récompenses</strong>
                        <span>Motivez vos colocataires</span>
                    </div>
                </div>
                <div class="al-feat">
                    <div class="al-feat-icon">🏆</div>
                    <div class="al-feat-text">
                        <strong>Classement en temps réel</strong>
                        <span>Qui entretient le mieux la maison ?</span>
                    </div>
                </div>
            </div>
        </div>

        <div class="auth-right">
            <h1 class="auth-title">Bon retour ! 👋</h1>
            <p class="auth-sub">Connectez-vous pour accéder à votre espace.</p>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" style="color:var(--red);font-size:13px;margin-bottom:14px;font-weight:600;"></div>

                <div class="form-group">
                    <label asp-for="Email" class="form-lbl">Email</label>
                    <input asp-for="Email" class="form-inp" placeholder="nom@exemple.com" required />
                </div>
                <div class="form-group">
                    <label asp-for="Password" class="form-lbl">Mot de passe</label>
                    <input asp-for="Password" type="password" class="form-inp" placeholder="••••••••" required />
                </div>

                <div class="auth-opts">
                    <label class="remember">
                        <input asp-for="RememberMe" type="checkbox" /> Se souvenir
                    </label>
                    <a href="#" class="forgot">Oublié ?</a>
                </div>

                <button type="submit" class="btn-submit">Se connecter →</button>
                <div class="auth-foot">Pas de compte ? <a asp-action="Register">S'inscrire</a></div>
            </form>
        </div>

    </div>
</body>
</html>

@model Bayti.ViewModels.ProfileViewModel
@{
    ViewData["Title"] = "Mon Profil";
}

<div class="page-wrap">
    
    <div class="page-header mb-8">
        <h1 class="page-title">👤 Mon Profil</h1>
        <p style="font-size:14px; color:var(--ink-3); margin-top:4px;">Gérez vos informations personnelles et votre avatar.</p>
    </div>

    @if (TempData["Success"] != null) {
        <div class="alert alert-success"><i class="fa-solid fa-circle-check"></i> @TempData["Success"]</div>
    }

    <form asp-action="Profile" method="post">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-4"></div>
        <input type="hidden" asp-for="AvatarUrl" id="avatar-input" />

        <div class="profile-grid">
            <!-- Sidebar: Avatar & Identity -->
            <div class="profile-side">
                <div class="card p-0 overflow-hidden">
                    <div class="profile-cover">
                        <div class="cover-bubbles">
                            <div class="cb cb-1"></div>
                            <div class="cb cb-2"></div>
                        </div>
                    </div>
                    <div class="profile-identity">
                        <div class="profile-avatar-wrapper">
                            <img id="profile-preview" src="@Url.Content(Model.AvatarUrl ?? "/images/avatars/avatar1.png")" alt="Avatar" />
                            <div class="avatar-edit-badge"><i class="fa-solid fa-camera"></i></div>
                        </div>
                        <h2 class="profile-name-display">@Model.FullName</h2>
                        <p class="profile-email-display">@Model.Email</p>

                        <div class="profile-stats mt-4">
                            <div class="stat-badge @(ViewBag.IsAdmin == true ? "badge-admin" : "badge-member")">
                                <i class="fa-solid @(ViewBag.IsAdmin == true ? "fa-crown" : "fa-user")"></i>
                                @(ViewBag.IsAdmin == true ? "Administrateur" : "Membre")
                            </div>
                            <div class="stat-badge badge-points">
                                <i class="fa-solid fa-bolt-lightning"></i> @ViewBag.Points pts
                            </div>
                        </div>
                    </div>

                    <div class="p-6 pt-2 border-t border-border">
                        <label class="form-label-premium text-center mb-4" style="display:block;">Changer d'avatar</label>
                        <div class="avatar-picker-grid">
                            @{
                                var avatars = new List<string> { 
                                    "/images/avatars/avatar1.png", 
                                    "/images/avatars/avatar2.png", 
                                    "/images/avatars/avatar3.png", 
                                    "/images/avatars/avatar4.png", 
                                    "/images/avatars/avatar5.png"
                                };
                            }
                            @foreach (var url in avatars) {
                                var resolvedUrl = url.StartsWith("http") ? url : Url.Content(url);
                                <div class="avatar-item @(Model.AvatarUrl == url ? "is-active" : "")" onclick="selectAvatar('@resolvedUrl', this, '@url')">
                                    <img src="@resolvedUrl" alt="Avatar" />
                                    <div class="avatar-check"><i class="fa-solid fa-check"></i></div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Main: Forms -->
            <div class="profile-main">
                <div class="card card-p mb-6">
                    <h3 class="section-title mb-6" style="font-size:18px;">🆔 Informations personnelles</h3>
                    <div class="form-grid">
                        <div class="form-group-premium">
                            <label asp-for="FullName" class="form-label-premium">Nom complet</label>
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-user"></i>
                                <input asp-for="FullName" class="input-premium" placeholder="Votre nom..." />
                            </div>
                            <span asp-validation-for="FullName" class="text-danger"></span>
                        </div>
                        <div class="form-group-premium">
                            <label asp-for="Email" class="form-label-premium">Adresse email</label>
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-envelope"></i>
                                <input asp-for="Email" class="input-premium" placeholder="email@exemple.com" />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <div class="card card-p mb-8">
                    <h3 class="section-title mb-6" style="font-size:18px;">🔒 Sécurité</h3>
                    <div class="form-grid">
                        <div class="form-group-premium">
                            <label asp-for="NewPassword" class="form-label-premium">Nouveau mot de passe</label>
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-lock"></i>
                                <input asp-for="NewPassword" type="password" class="input-premium" placeholder="••••••••" />
                            </div>
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>
                        <div class="form-group-premium">
                            <label asp-for="ConfirmPassword" class="form-label-premium">Confirmer</label>
                            <div class="input-icon-wrap">
                                <i class="fa-solid fa-shield-halved"></i>
                                <input asp-for="ConfirmPassword" type="password" class="input-premium" placeholder="••••••••" />
                            </div>
                            <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                        </div>
                    </div>
                    <p class="hint-text mt-4">Laissez vide si vous ne souhaitez pas modifier votre mot de passe.</p>
                </div>

                <div style="display:flex; justify-content:flex-end;">
                    <button type="submit" class="btn btn-coral py-4 px-10" style="font-size:16px;">
                        <i class="fa-solid fa-save mr-2"></i> Enregistrer les modifications
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<style>
.profile-grid { display: grid; grid-template-columns: 340px 1fr; gap: 32px; align-items: start; }
@@media (max-width: 900px) { .profile-grid { grid-template-columns: 1fr; } }

/* Cover Banner */
.profile-cover {
    height: 120px;
    background: linear-gradient(135deg, var(--coral), var(--coral-bg));
    position: relative;
    overflow: hidden;
}
.cover-bubbles { position: absolute; inset: 0; pointer-events: none; }
.cb { position: absolute; background: rgba(255,255,255,0.2); border-radius: 50%; }
.cb-1 { width: 100px; height: 100px; top: -20px; right: -20px; backdrop-filter: blur(4px); }
.cb-2 { width: 60px; height: 60px; bottom: -30px; left: 20px; backdrop-filter: blur(2px); }

/* Identity */
.profile-identity { padding: 0 24px 24px; text-align: center; margin-top: -60px; position: relative; }
.profile-avatar-wrapper { position: relative; width: 120px; height: 120px; margin: 0 auto 16px; }
.profile-avatar-wrapper img { width: 100%; height: 100%; border-radius: 40px; object-fit: cover; border: 5px solid var(--surface); box-shadow: var(--shadow-sm); background: var(--surface); }
.avatar-edit-badge { position: absolute; bottom: -4px; right: -4px; width: 36px; height: 36px; background: var(--coral); color: white; border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 3px solid var(--surface); font-size: 14px; box-shadow: var(--shadow-coral-sm); z-index: 10; }

.profile-name-display { font-family: var(--font-display); font-size: 24px; font-weight: 900; color: var(--ink); line-height: 1.2; }
.profile-email-display { font-size: 14px; color: var(--ink-4); font-weight: 500; margin-top: 4px; }

/* Stats & Badges */
.profile-stats { display: flex; justify-content: center; gap: 8px; flex-wrap: wrap; }
.stat-badge { padding: 6px 14px; border-radius: 99px; font-size: 12px; font-weight: 800; display: flex; align-items: center; gap: 6px; }
.badge-admin { background: var(--coral-bg); color: var(--coral); border: 1px solid rgba(255,107,107,0.2); }
.badge-member { background: var(--blue-bg); color: var(--blue); border: 1px solid rgba(74,144,226,0.2); }
.badge-points { background: var(--amber-bg); color: var(--amber); border: 1px solid rgba(245,166,35,0.2); }

/* Avatar Picker */
.avatar-picker-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; justify-content: center; }
.avatar-item { position: relative; cursor: pointer; transition: var(--t-fast); border-radius: 16px; background: var(--bg); padding: 4px; border: 2px solid transparent; }
.avatar-item img { width: 100%; border-radius: 12px; transition: var(--t-fast); }
.avatar-item:hover { border-color: var(--border-strong); transform: translateY(-3px); }
.avatar-item.is-active { border-color: var(--coral); background: var(--coral-bg); transform: scale(1.05); }
.avatar-check { position: absolute; top: -6px; right: -6px; width: 22px; height: 22px; background: var(--coral); color: white; border-radius: 50%; display: none; align-items: center; justify-content: center; font-size: 10px; border: 2px solid var(--surface); box-shadow: var(--shadow-sm); z-index: 5; }
.avatar-item.is-active .avatar-check { display: flex; }

.form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; }
.input-icon-wrap { position: relative; }
.input-icon-wrap i { position: absolute; left: 16px; top: 50%; transform: translateY(-50%); color: var(--ink-4); font-size: 14px; }
.input-icon-wrap .input-premium { padding-left: 44px; }

.hint-text { font-size: 13px; font-style: italic; color: var(--ink-4); }
</style>

@section Scripts {
    <script>
        function selectAvatar(resolvedUrl, el, rawUrl) {
            document.getElementById('avatar-input').value = rawUrl;
            document.getElementById('profile-preview').src = resolvedUrl;
            document.querySelectorAll('.avatar-item').forEach(opt => opt.classList.remove('is-active'));
            el.classList.add('is-active');
        }
    </script>
}

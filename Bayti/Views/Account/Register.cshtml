@model Bayti.ViewModels.RegisterViewModel
@{ Layout = null; }
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Inscription – Bayti</title>
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
    <link rel="stylesheet" href="~/css/variables.css" asp-append-version="true"/>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin:0; padding:0; }
        body { min-height: 100vh; background: var(--bg); font-family: var(--font-body); display: grid; place-items: center; padding: 32px 20px; }

        .register-card {
            background: var(--surface);
            width: 100%; max-width: 540px;
            padding: 52px 48px;
            border-radius: var(--r-xl);
            box-shadow: var(--shadow-lg);
            border: 1px solid var(--border);
        }

        .reg-header { text-align:center; margin-bottom:32px; }
        .reg-brand { font-family:var(--font-display); font-size:26px; font-weight:900; color:var(--coral); letter-spacing:-0.5px; margin-bottom:14px; }
        .reg-title { font-family:var(--font-display); font-size:24px; font-weight:900; color:var(--ink); letter-spacing:-0.5px; margin-bottom:6px; }
        .reg-sub { font-size:14px; color:var(--ink-3); }

        .form-group { margin-bottom:16px; }
        .form-lbl { display:block; font-size:11px; font-weight:800; color:var(--ink-3); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:8px; }
        .form-inp { width:100%; padding:12px 16px; background:var(--bg-2); border:1.5px solid var(--border); border-radius:var(--r-sm); font-family:var(--font-body); font-size:14px; font-weight:500; color:var(--ink); transition:var(--t-fast); }
        .form-inp:focus { outline:none; background:var(--surface); border-color:var(--coral); box-shadow:var(--coral-glow); }
        .form-inp::placeholder { color:var(--ink-4); }

        .form-row { display:grid; grid-template-columns:1fr 1fr; gap:14px; }

        /* Avatar picker */
        .av-section { margin-bottom:24px; }
        .av-label { display:block; font-size:11px; font-weight:800; color:var(--ink-3); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:10px; }
        .av-grid { display:flex; flex-wrap:wrap; gap:8px; }
        .av-opt { cursor:pointer; border-radius:var(--r-sm); border:2.5px solid transparent; padding:2px; transition:var(--t-spring); position:relative; }
        .av-opt img { width:48px; height:48px; border-radius:var(--r-xs); display:block; }
        .av-opt:hover { transform:scale(1.06); border-color:var(--border-strong); }
        .av-opt.active { border-color:var(--coral); box-shadow:var(--coral-glow); transform:scale(1.1); }
        .av-opt.active::after { content:'✓'; position:absolute; top:-7px; right:-7px; width:18px; height:18px; background:var(--coral); color:white; border-radius:50%; font-size:10px; font-weight:900; display:flex; align-items:center; justify-content:center; border:2px solid white; }

        .btn-submit { width:100%; padding:14px; background:var(--grad-coral); color:white; border:none; border-radius:var(--r-md); font-family:var(--font-display); font-size:16px; font-weight:800; cursor:pointer; transition:var(--t-spring); box-shadow:var(--shadow-coral-sm); margin-bottom:16px; }
        .btn-submit:hover { transform:translateY(-2px); box-shadow:var(--shadow-coral); }

        .auth-foot { text-align:center; font-size:14px; color:var(--ink-3); font-weight:600; }
        .auth-foot a { color:var(--coral); font-weight:800; }
    </style>
</head>
<body>
    <div class="register-card">
        <div class="reg-header">
            <div class="reg-brand">🏠 Bayti</div>
            <h1 class="reg-title">Créer un compte</h1>
            <p class="reg-sub">Rejoignez votre colocation et gérez le ménage ensemble.</p>
        </div>

        <form asp-action="Register" method="post">
            <div asp-validation-summary="All" style="color:var(--red);font-size:13px;margin-bottom:14px;font-weight:600;"></div>

            <div class="form-group">
                <label asp-for="FullName" class="form-lbl">Nom complet</label>
                <input asp-for="FullName" class="form-inp" placeholder="Jean Dupont" required />
            </div>
            <div class="form-group">
                <label asp-for="Email" class="form-lbl">Adresse Email</label>
                <input asp-for="Email" class="form-inp" placeholder="jean@exemple.com" required />
            </div>
            <div class="form-row">
                <div class="form-group">
                    <label asp-for="Password" class="form-lbl">Mot de passe</label>
                    <input asp-for="Password" type="password" class="form-inp" placeholder="••••••••" required />
                </div>
                <div class="form-group">
                    <label asp-for="ConfirmPassword" class="form-lbl">Confirmation</label>
                    <input asp-for="ConfirmPassword" type="password" class="form-inp" placeholder="••••••••" required />
                </div>
            </div>

            <div class="av-section">
                <span class="av-label">Votre avatar</span>
                <input type="hidden" asp-for="AvatarUrl" id="av-input" value="/images/avatars/avatar1.png" />
                <div class="av-grid">
                    @{
                        var avs = new[]{
                            "/images/avatars/avatar1.png","/images/avatars/avatar2.png",
                            "/images/avatars/avatar3.png","/images/avatars/avatar4.png",
                            "/images/avatars/avatar5.png",
                            "https://api.dicebear.com/7.x/avataaars/png?seed=Felix",
                            "https://api.dicebear.com/7.x/avataaars/png?seed=Aneka",
                            "https://api.dicebear.com/7.x/avataaars/png?seed=Milo"
                        };
                    }
                    @foreach (var url in avs)
                    {
                        var src = url.StartsWith("http") ? url : Url.Content(url);
                        <div class="av-opt @(url=="/images/avatars/avatar1.png"?"active":"")" onclick="pickAv('@url',this)">
                            <img src="@src" />
                        </div>
                    }
                </div>
            </div>

            <button type="submit" class="btn-submit">Créer mon compte →</button>
            <div class="auth-foot">Déjà inscrit ? <a asp-action="Login">Se connecter</a></div>
        </form>
    </div>

    <script>
        function pickAv(url, el) {
            document.getElementById('av-input').value = url;
            document.querySelectorAll('.av-opt').forEach(o => o.classList.remove('active'));
            el.classList.add('active');
        }
    </script>
</body>
</html>

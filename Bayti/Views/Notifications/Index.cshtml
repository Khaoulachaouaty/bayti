@model IEnumerable<Bayti.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
        <div>
            <h1 class="page-title">🔔 Notifications</h1>
            <p style="font-size:14px;color:var(--ink-3);margin-top:4px;">
                @if (unreadCount > 0) { <text><span style="color:var(--coral);font-weight:700;">@unreadCount non lue(s)</span> – </text> }
                Restez informé de votre colocation.
            </p>
        </div>
        <div style="display:flex;gap:10px;">
            @if (unreadCount > 0) {
                <form asp-action="MarkAllAsRead" method="post">
                    <button type="submit" class="btn btn-ghost">
                        <i class="fa-solid fa-check-double"></i> Tout marquer lu
                    </button>
                </form>
            }
        </div>
    </div>

    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">🔕</div>
            <h3>Tout est calme !</h3>
            <p>Aucune notification pour le moment.</p>
        </div>
    } else {
        <div class="notif-list">
            @foreach (var notif in Model) {
                <div class="notif-card @(notif.IsRead ? "is-read" : "is-unread") @(string.IsNullOrEmpty(notif.ActionUrl) || notif.ActionUrl == "/" ? "" : "is-clickable")"
                     @(string.IsNullOrEmpty(notif.ActionUrl) || notif.ActionUrl == "/" ? "" : $"onclick=window.location.href='{notif.ActionUrl}'")>
                    @if (!notif.IsRead) {
                        <div class="notif-dot"></div>
                    }
                    <div class="notif-icon-wrap @(notif.Type == "Warning" || notif.Type == "Penalty" ? "ni-danger" : notif.Type == "Success" ? "ni-success" : "ni-info")">
                        @if (notif.Type == "Warning" || notif.Type == "Penalty") {
                            <i class="fa-solid fa-triangle-exclamation"></i>
                        } else if (notif.Type == "Success") {
                            <i class="fa-solid fa-circle-check"></i>
                        } else {
                            <i class="fa-solid fa-bell"></i>
                        }
                    </div>
                    <div class="notif-body">
                        <div class="notif-top">
                            <h4 class="notif-title">@notif.Title</h4>
                            <span class="notif-time">@notif.CreatedAt.ToString("dd/MM HH:mm")</span>
                        </div>
                        <p class="notif-msg">@notif.Message</p>
                    </div>
                    @if (!notif.IsRead) {
                        <form asp-action="MarkAsRead" asp-route-id="@notif.Id" method="post" style="z-index: 10;">
                            <button type="submit" class="notif-read-btn" title="Marquer comme lu" onclick="event.stopPropagation();">
                                <i class="fa-solid fa-check"></i>
                            </button>
                        </form>
                    }
                </div>
            }
        </div>
    }
</div>

<style>
.notif-list { display: flex; flex-direction: column; gap: 10px; }
.notif-card {
    display: flex; align-items: center; gap: 16px;
    padding: 18px 22px; border-radius: 18px;
    background: var(--surface); border: 1.5px solid var(--border);
    box-shadow: var(--shadow-xs); transition: var(--t-fast);
    position: relative;
}
.notif-card:hover { box-shadow: var(--shadow-sm); transform: translateX(4px); }
.notif-card.is-unread { background: linear-gradient(135deg, #FFF8F5, #FFFFFF); border-color: rgba(255,107,107,0.22); }
.notif-card.is-read { opacity: 0.65; }
.notif-card.is-clickable { cursor: pointer; }

.notif-dot { position: absolute; left: -5px; top: 50%; transform: translateY(-50%); width: 10px; height: 10px; background: var(--coral); border-radius: 50%; box-shadow: 0 0 0 3px var(--coral-bg); }

.notif-icon-wrap { width: 46px; height: 46px; border-radius: 14px; display: flex; align-items: center; justify-content: center; font-size: 18px; flex-shrink: 0; }
.ni-info    { background: var(--coral-bg); color: var(--coral); }
.ni-danger  { background: var(--amber-bg); color: var(--amber); }
.ni-success { background: var(--green-bg); color: var(--green); }

.notif-body { flex: 1; min-width: 0; }
.notif-top { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 4px; }
.notif-title { font-size: 15px; font-weight: 800; color: var(--ink); margin: 0; }
.notif-time { font-size: 11px; font-weight: 700; color: var(--ink-4); white-space: nowrap; }
.notif-msg { font-size: 13px; color: var(--ink-3); line-height: 1.5; margin: 0; }

.notif-read-btn { width: 36px; height: 36px; border-radius: 10px; border: 1.5px solid var(--border); background: var(--bg-2); color: var(--green); font-size: 13px; cursor: pointer; transition: var(--t-spring); display: flex; align-items: center; justify-content: center; }
.notif-read-btn:hover { background: var(--green); color: white; border-color: var(--green); transform: scale(1.12); }
</style>

@model IEnumerable<Bayti.Models.Notification>
@{
    ViewData["Title"] = "Notifications";
    var unreadCount = Model.Count(n => !n.IsRead);
}

<div class="header-section mb-10">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
            <h1 class="page-title">Mes Notifications</h1>
            <p class="page-subtitle">Restez informé de tout ce qui se passe dans la colocation.</p>
        </div>
        <div class="flex gap-4">
            <a asp-action="TestNotification" class="btn" style="background: white; border: 1px solid var(--color-border); border-radius: 12px; font-weight: 700;">
                <i class="fa-solid fa-vial mr-2"></i> Tester
            </a>
            @if (unreadCount > 0)
            {
                <form asp-action="MarkAllAsRead" method="post">
                    <button type="submit" class="btn-premium" style="background: #F1F5F9; color: var(--color-text-primary);">
                        <i class="fa-solid fa-check-double mr-2"></i>
                        Tout marquer comme lu
                    </button>
                </form>
            }
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="empty-state-fine">
        <div class="empty-illustration">
            <i class="fa-regular fa-bell-slash"></i>
        </div>
        <p>Aucune notification pour le moment. Tout est calme !</p>
    </div>
}
else
{
    <div class="notifications-list flex flex-col gap-4">
        @foreach (var notif in Model)
        {
            <div class="notif-card @(notif.IsRead ? "read" : "unread")">
                <div class="notif-icon-container">
                    @if (notif.Type == "Warning" || notif.Type == "Penalty")
                    {
                        <div class="notif-icon danger"><i class="fa-solid fa-triangle-exclamation"></i></div>
                    }
                    else if (notif.Type == "Success")
                    {
                        <div class="notif-icon success"><i class="fa-solid fa-check"></i></div>
                    }
                    else
                    {
                        <div class="notif-icon info"><i class="fa-solid fa-info"></i></div>
                    }
                </div>
                
                <div class="notif-content">
                    <div class="notif-header">
                        <h4 class="notif-title">@notif.Title</h4>
                        <span class="notif-time">@notif.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <p class="notif-msg">@notif.Message</p>
                </div>
                
                <div class="notif-actions">
                    @if (!notif.IsRead)
                    {
                        <form asp-action="MarkAsRead" asp-route-id="@notif.Id" method="post">
                            <button type="submit" class="btn-mark-read" title="Marquer comme lu">
                                <i class="fa-solid fa-check"></i>
                            </button>
                        </form>
                    }
                </div>
                
                @if (!notif.IsRead)
                {
                    <div class="unread-dot"></div>
                }
            </div>
        }
    </div>
}

<style>
    .notif-card {
        background: white;
        border-radius: 20px;
        padding: 20px;
        display: flex;
        gap: 20px;
        align-items: flex-start;
        border: 1px solid #F1F5F9;
        transition: all 0.3s ease;
        position: relative;
    }
    
    .notif-card.unread {
        border-color: rgba(212, 165, 138, 0.3);
        background: #FFFAF8;
        box-shadow: 0 4px 15px rgba(212, 165, 138, 0.05);
    }
    
    .notif-card.read {
        opacity: 0.7;
    }

    .notif-icon-container { flex-shrink: 0; }
    .notif-icon {
        width: 44px; height: 44px; border-radius: 14px;
        display: flex; align-items: center; justify-content: center;
        font-size: 18px;
    }
    .notif-icon.info { background: var(--color-primary-bg); color: var(--color-primary); }
    .notif-icon.danger { background: var(--color-danger-bg); color: var(--color-danger); }
    .notif-icon.success { background: var(--color-success-bg); color: var(--color-success); }

    .notif-content { flex-grow: 1; min-width: 0; }
    .notif-header { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 6px; }
    .notif-title { font-size: 16px; font-weight: 800; color: var(--color-text-primary); margin: 0; }
    .notif-time { font-size: 11px; font-weight: 700; color: #94A3B8; }
    .notif-msg { font-size: 14px; color: var(--color-text-secondary); line-height: 1.5; margin: 0; }

    .notif-actions { display: flex; align-items: center; }
    .btn-mark-read {
        width: 36px; height: 36px; border-radius: 10px; border: none; cursor: pointer;
        background: white; color: var(--color-primary); box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        transition: all 0.2s; display: flex; align-items: center; justify-content: center;
    }
    .btn-mark-read:hover { background: var(--color-primary); color: white; transform: scale(1.05); }

    .unread-dot {
        position: absolute; top: 20px; left: -4px; width: 8px; height: 8px;
        background: var(--color-primary); border-radius: 50%;
    }
</style>

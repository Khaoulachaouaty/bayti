@model IEnumerable<Bayti.Models.TaskTemplate>
@using System.Security.Claims
@{
    ViewData["Title"] = "Règles des Tâches";
    var isAdmin = User.FindFirstValue("IsAdmin") == "True";
    var groupedTasks = Model.GroupBy(t => t.Category?.Name ?? "Sans catégorie");
}

<div class="page-wrap">

    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px; margin-bottom:28px;">
        <div>
            <h1 class="page-title">⚡ Règles & Automatisations</h1>
            <p style="font-size:14px; color:var(--ink-3); margin-top:4px;">Gérez la génération automatique des tâches de votre tribu.</p>
        </div>
        @if (isAdmin) {
            <a asp-action="Create" class="btn btn-coral"><i class="fa-solid fa-plus"></i> Nouvelle règle</a>
        }
    </div>

    <!-- Quick stats -->
    <div class="tt-stats mb-8">
        <div class="tt-stat">
            <div class="ibox ibox-md ibox-coral"><i class="fa-solid fa-robot"></i></div>
            <div>
                <div class="tt-stat-label">Règles actives</div>
                <div class="tt-stat-val">@Model.Count(t => !t.IsPaused)</div>
            </div>
        </div>
        <div class="tt-stat">
            <div class="ibox ibox-md ibox-amber"><i class="fa-solid fa-bolt"></i></div>
            <div>
                <div class="tt-stat-label">Points/jour potentiels</div>
                <div class="tt-stat-val">@Model.Where(t => t.RecurrenceType == "Daily").Sum(t => t.Points) ⭐</div>
            </div>
        </div>
        <div class="tt-stat">
            <div class="ibox ibox-md ibox-mint"><i class="fa-solid fa-pause"></i></div>
            <div>
                <div class="tt-stat-label">En pause</div>
                <div class="tt-stat-val">@Model.Count(t => t.IsPaused)</div>
            </div>
        </div>
    </div>

    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">🪄</div>
            <h3>Aucune règle</h3>
            <p>Automatisez vos tâches quotidiennes pour gagner du temps.</p>
        </div>
    }

    @foreach (var group in groupedTasks) {
        <div class="tt-group mb-8">
            <h2 class="tt-group-title">@group.Key</h2>
            <div class="tt-grid">
                @foreach (var item in group) {
                    <div class="tt-card @(item.IsPaused ? "is-paused" : "")">
                        <div class="tt-card-top">
                            <span class="tt-recurrence">
                                <i class="fa-solid fa-clock-rotate-left"></i>
                                @(item.RecurrenceType == "Daily" ? "Quotidien" : item.RecurrenceType == "Weekly" ? "Hebdo" : item.RecurrenceType == "Monthly" ? "Mensuel" : item.RecurrenceType == "Once" ? "Une fois" : "Personnalisé")
                            </span>
                            <span class="tt-pts">+@item.Points ⭐</span>
                        </div>
                        <h3 class="tt-title">@item.Title</h3>
                        <p class="tt-desc">@(item.Description ?? "Aucune description.")</p>
                        <div class="tt-card-footer">
                            <div class="tt-status">
                                <span class="tt-status-dot"></span>
                                @(item.IsPaused ? "En pause" : "Active")
                            </div>
                            <div class="tt-actions">
                                <a asp-action="TogglePause" asp-route-id="@item.Id" class="tt-btn @(item.IsPaused ? "tt-btn-resume" : "tt-btn-pause")" title="@(item.IsPaused ? "Reprendre" : "Pause")">
                                    <i class="fa-solid @(item.IsPaused ? "fa-play" : "fa-pause")"></i>
                                </a>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="tt-btn tt-btn-edit"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('Supprimer cette règle ?')" style="display:inline;">
                                    <button type="submit" class="tt-btn tt-btn-del"><i class="fa-solid fa-trash-can"></i></button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>

<style>
.tt-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
.tt-stat { background: var(--surface); border: 1.5px solid var(--border); border-radius: 16px; padding: 18px 20px; display: flex; align-items: center; gap: 14px; box-shadow: var(--shadow-xs); }
.tt-stat-label { font-size: 11px; font-weight: 700; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.5px; }
.tt-stat-val { font-family: var(--font-display); font-size: 22px; font-weight: 900; color: var(--ink); }

.tt-group-title { font-size: 12px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: var(--ink-3); padding: 0 0 12px 14px; border-left: 3px solid var(--coral); margin-bottom: 16px; }
.tt-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(290px, 1fr)); gap: 18px; }

.tt-card { background: var(--surface); border: 1.5px solid var(--border); border-radius: 20px; padding: 22px; transition: var(--t-spring); box-shadow: var(--shadow-xs); }
.tt-card:hover:not(.is-paused) { border-color: var(--coral); transform: translateY(-4px); box-shadow: var(--shadow-md); }
.tt-card.is-paused { opacity: 0.6; background: var(--bg-2); }

.tt-card-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
.tt-recurrence { font-size: 11px; font-weight: 800; color: var(--ink-3); background: var(--bg-2); padding: 4px 10px; border-radius: 8px; display: flex; align-items: center; gap: 6px; }
.tt-pts { font-weight: 800; color: var(--coral); font-size: 15px; }
.tt-title { font-family: var(--font-display); font-size: 17px; font-weight: 800; color: var(--ink); margin-bottom: 8px; }
.tt-desc { font-size: 13px; color: var(--ink-3); line-height: 1.5; flex: 1; margin-bottom: 18px; }

.tt-card-footer { display: flex; justify-content: space-between; align-items: center; padding-top: 14px; border-top: 1px solid var(--border); }
.tt-status { display: flex; align-items: center; gap: 7px; font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--ink-3); }
.tt-status-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--green); box-shadow: 0 0 0 3px var(--green-bg); }
.is-paused .tt-status-dot { background: var(--ink-4); box-shadow: 0 0 0 3px var(--bg-2); }

.tt-actions { display: flex; gap: 6px; }
.tt-btn { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: 1.5px solid var(--border); background: var(--bg-2); color: var(--ink-3); transition: var(--t-fast); cursor: pointer; text-decoration: none; font-size: 12px; }
.tt-btn-pause:hover  { color: var(--amber); background: var(--amber-bg); border-color: rgba(245,166,35,0.3); }
.tt-btn-resume:hover { color: var(--green); background: var(--green-bg); border-color: rgba(46,204,135,0.3); }
.tt-btn-edit:hover   { color: var(--blue);  background: var(--blue-bg);  border-color: rgba(74,144,226,0.3); }
.tt-btn-del:hover    { color: var(--red);   background: var(--red-bg);   border-color: rgba(255,107,107,0.3); }
.tt-btn:hover { transform: scale(1.1); }
</style>

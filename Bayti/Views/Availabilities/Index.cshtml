@model IEnumerable<Bayti.Models.Availability>
@{
    ViewData["Title"] = "Mes Disponibilités";
    // Dictionnaire pour traduire les jours de l'anglais vers le français
    var daysFr = new Dictionary<string, string> {
        {"Monday", "Lundi"}, {"Tuesday", "Mardi"}, {"Wednesday", "Mercredi"}, 
        {"Thursday", "Jeudi"}, {"Friday", "Vendredi"}, {"Saturday", "Samedi"}, {"Sunday", "Dimanche"}
    };
    // Trier les jours de la semaine dans l'ordre : Lundi, Mardi, Mercredi, Jeudi, Vendredi, Samedi, Dimanche
    var sortedModel = Model.OrderBy(a => a.DayKey == "Sunday" ? 7 : 
                                       a.DayKey == "Saturday" ? 6 :
                                       a.DayKey == "Friday" ? 5 :
                                       a.DayKey == "Thursday" ? 4 :
                                       a.DayKey == "Wednesday" ? 3 :
                                       a.DayKey == "Tuesday" ? 2 : 1).ToList();
}

<div class="page-wrap">
    <div class="page-header mb-8">
        <div style="display:flex; justify-content:space-between; align-items:flex-end; flex-wrap:wrap; gap:20px;">
            <div>
                <h1 class="page-title">📅 Mes Disponibilités</h1>
                <p class="page-subtitle">Configurez vos créneaux pour l'attribution intelligente des tâches.</p>
            </div>
            <div class="avail-summary-pills">
                <div class="pill pill-mint">
                    <i class="fa-solid fa-check-double"></i>
                    <span>@Model.Count(a => a.IsActive) Jours Actifs</span>
                </div>
                <div class="pill pill-coral">
                    <i class="fa-solid fa-bolt"></i>
                    <span>Mode @ViewBag.AssignmentMode</span>
                </div>
            </div>
        </div>
    </div>

    @if (ViewBag.AssignmentMode != "Auto")
    {
        <div class="alert alert-warning mb-8">
            <div class="ibox ibox-sm ibox-amber"><i class="fa-solid fa-circle-info"></i></div>
            <div>
                <strong>Mode @ViewBag.AssignmentMode actif :</strong> Vos disponibilités ne sont prises en compte que lorsque la colocation est en mode <b>Automatique</b>.
            </div>
        </div>
    }

    <form id="availForm" asp-action="Update" method="post">
        <div class="avail-grid">
            @for (int i = 0; i < sortedModel.Count; i++)
            {
                string dayIcon = sortedModel[i].DayKey switch {
                    "Monday" => "fa-calendar-day",
                    "Tuesday" => "fa-sun",
                    "Wednesday" => "fa-cloud-sun",
                    "Thursday" => "fa-wind",
                    "Friday" => "fa-mug-hot",
                    "Saturday" => "fa-couch",
                    "Sunday" => "fa-bed",
                    _ => "fa-clock"
                };

                <div class="avail-card @(sortedModel[i].IsActive ? "is-active" : "is-off")">
                    <input type="hidden" name="availabilities[@i].Id" value="@sortedModel[i].Id" />
                    
                    <div class="avail-card-bg"></div>

                    <div class="avail-header">
                        <div class="day-info">
                            <div class="day-icon"><i class="fa-solid @dayIcon"></i></div>
                            <span class="day-name">@daysFr[sortedModel[i].DayKey]</span>
                        </div>
                        <label class="premium-switch">
                            <input type="checkbox" name="availabilities[@i].IsActive" value="true" @(sortedModel[i].IsActive ? "checked" : "") onchange="toggleCard(this)" />
                            <input type="hidden" name="availabilities[@i].IsActive" value="false" />
                            <span class="p-slider"></span>
                        </label>
                    </div>

                    <div class="avail-body">
                        <div class="time-row">
                            <div class="time-box">
                                <input type="time" name="availabilities[@i].StartTime" value="@sortedModel[i].StartTime" @(sortedModel[i].IsActive ? "" : "disabled") />
                            </div>
                            <div class="time-sep"><i class="fa-solid fa-arrow-right-long"></i></div>
                            <div class="time-box">
                                <input type="time" name="availabilities[@i].EndTime" value="@sortedModel[i].EndTime" @(sortedModel[i].IsActive ? "" : "disabled") />
                            </div>
                        </div>
                    </div>
                    
                    <div class="avail-footer">
                        <div class="status-pill @(sortedModel[i].IsActive ? "active" : "")">
                            <span class="status-dot"></span>
                            <span class="status-label">@(sortedModel[i].IsActive ? "Disponible" : "Repos")</span>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div style="display: flex; justify-content: center; margin-top: 50px; margin-bottom: 40px;">
            <button type="submit" class="btn-save-premium">
                <i class="fa-solid fa-cloud-arrow-up"></i>
                Enregistrer mes horaires
            </button>
        </div>
    </form>
</div>

<style>
    .page-header { margin-bottom: 32px; }
    .page-title { font-family: var(--font-display); font-size: 34px; font-weight: 900; color: var(--ink); letter-spacing: -0.8px; }
    .page-subtitle { color: var(--ink-3); font-size: 15px; margin-top: 6px; font-weight: 500; }

    .avail-summary-pills { display: flex; gap: 12px; }
    .pill { display: flex; align-items: center; gap: 8px; padding: 10px 20px; border-radius: 99px; font-size: 13px; font-weight: 800; box-shadow: var(--shadow-xs); }
    .pill-mint { background: var(--mint-bg); color: var(--mint-dark); border: 1.5px solid rgba(0,201,167,0.15); }
    .pill-coral { background: var(--coral-bg); color: var(--coral-dark); border: 1.5px solid rgba(255,107,107,0.15); }

    .alert-warning {
        background: var(--amber-bg); border: 1.5px solid rgba(245,166,35,0.15); 
        border-radius: 20px; padding: 18px 24px; color: var(--ink-2); 
        font-size: 14px; display: flex; align-items: center; gap: 16px;
    }

    .avail-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 20px; }
    
    .avail-card { 
        background: var(--surface); border: 1.5px solid var(--border); border-radius: 24px; 
        padding: 20px; position: relative; overflow: hidden; transition: var(--t-spring);
        box-shadow: var(--shadow-xs); display: flex; flex-direction: column; gap: 16px;
    }
    .avail-card:hover { transform: translateY(-5px); border-color: var(--coral); box-shadow: var(--shadow-sm); }
    .avail-card.is-off { background: var(--bg-2); border-style: dashed; opacity: 0.7; }
    
    .avail-card-bg { 
        position: absolute; top: -40px; right: -40px; width: 100px; height: 100px; 
        background: radial-gradient(circle, var(--coral-bg) 0%, transparent 70%); 
        opacity: 0.3; pointer-events: none;
    }

    .avail-header { display: flex; justify-content: space-between; align-items: center; }
    .day-info { display: flex; align-items: center; gap: 12px; }
    .day-icon { 
        width: 40px; height: 40px; border-radius: 12px; background: var(--bg-3); 
        color: var(--ink-4); display: flex; align-items: center; justify-content: center; 
        font-size: 16px; transition: var(--t-fast);
    }
    .is-active .day-icon { background: var(--grad-coral); color: white; box-shadow: var(--shadow-coral-sm); }
    .day-name { font-family: var(--font-display); font-size: 18px; font-weight: 800; color: var(--ink); }

    .avail-body { }
    .time-row { display: flex; align-items: center; gap: 8px; background: var(--bg); border-radius: 14px; padding: 4px; border: 1px solid var(--border); }
    .time-box { flex: 1; }
    .time-box input { 
        width: 100%; border: none; background: transparent; padding: 8px; 
        font-family: var(--font-body); font-weight: 700; color: var(--ink); outline: none;
        text-align: center; font-size: 14px;
    }
    .time-sep { color: var(--ink-4); font-size: 12px; }
    
    .avail-footer { border-top: 1px solid var(--border); padding-top: 12px; }
    .status-pill { display: inline-flex; align-items: center; gap: 6px; padding: 4px 12px; border-radius: 99px; background: var(--bg-3); transition: var(--t-fast); }
    .status-pill.active { background: var(--green-bg); }
    .status-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--ink-4); }
    .status-pill.active .status-dot { background: var(--green); box-shadow: 0 0 6px var(--green); }
    .status-label { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; color: var(--ink-4); }
    .status-pill.active .status-label { color: var(--green); }

    /* Premium Switch */
    .premium-switch { position: relative; width: 44px; height: 22px; cursor: pointer; }
    .premium-switch input { opacity: 0; width: 0; height: 0; }
    .p-slider { position: absolute; inset: 0; background: var(--border-strong); border-radius: 22px; transition: .4s; }
    .p-slider:before { 
        position: absolute; content: ""; height: 16px; width: 16px; 
        left: 3px; bottom: 3px; background: white; border-radius: 50%; 
        transition: .4s;
    }
    input:checked + .p-slider { background: var(--grad-coral); }
    input:checked + .p-slider:before { transform: translateX(22px); }

    .btn-save-premium {
        background: var(--grad-coral); color: white; border: none; 
        padding: 20px 56px; border-radius: 24px; font-family: var(--font-display); 
        font-size: 18px; font-weight: 900; cursor: pointer; transition: var(--t-spring);
        box-shadow: var(--shadow-coral); display: flex; align-items: center; gap: 14px;
    }
    .btn-save-premium:hover { transform: translateY(-6px) scale(1.03); box-shadow: 0 20px 50px rgba(255,107,107,0.45); }
</style>

<!-- active ou désactive une carte de disponibilité -->
<script>
    function toggleCard(checkbox) {
        const card = checkbox.closest('.avail-card');
        const inputs = card.querySelectorAll('input[type="time"]');
        const statusText = card.querySelector('.status-text');
        
        if (checkbox.checked) {
            card.classList.remove('is-off');
            card.classList.add('is-active');
            inputs.forEach(i => i.disabled = false);
            statusText.textContent = 'Disponible';
        } else {
            card.classList.remove('is-active');
            card.classList.add('is-off');
            inputs.forEach(i => i.disabled = true);
            statusText.textContent = 'Repos';
        }
    }
</script>

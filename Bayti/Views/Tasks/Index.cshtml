@using System.Security.Claims
@model IEnumerable<Bayti.Models.TaskInstance>
@{
    ViewData["Title"] = "Mes Tâches du Jour";
    int currentUserId = int.Parse(User.FindFirst("UserId")?.Value ?? "0");
    // Count only the current user's tasks for the progress bar
    var myTasks = Model.Where(t => t.AssignedUserId == currentUserId).ToList();
    var completedCount = myTasks.Count(t => t.Status == "Completed");
    var totalCount = myTasks.Count;
    var progress = totalCount > 0 ? (completedCount * 100 / totalCount) : 0;
}

@{
    bool hasClaimedTask = false; // no longer used
}

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header">
        <div style="display:flex; justify-content:space-between; align-items:center;">
            <div>
                <h1 class="page-title">🧹 Mes Tâches</h1>
                <p class="page-subtitle">@DateTime.Now.ToString("dddd dd MMMM", new System.Globalization.CultureInfo("fr-FR"))</p>
            </div>
            <div style="display:flex; gap:12px; align-items:center;">
                @if (User.FindFirst("IsAdmin")?.Value == "True")
                {
                    <a asp-action="GenerateTestTasks" class="btn btn-coral" title="Générer les tâches d'aujourd'hui">
                        <i class="fa-solid fa-rotate"></i> Générer
                    </a>
                }
                @if (User.FindFirst("IsAdmin")?.Value == "True" && ViewBag.AssignmentMode == "Manuel")
                {
                    <a asp-action="Manage" class="btn btn-ghost">
                        <i class="fa-solid fa-crown"></i> Gérer toutes
                    </a>
                }
            </div>
        </div>
    </div>

    <!-- Dashboard Progress -->
    <div class="dashboard-stats mb-8">
        @if (User.FindFirst("IsAdmin")?.Value == "True" && ViewBag.AssignmentMode != "Participatif")
        {
            <!-- Household Progress -->
            <div class="stat-card stat-card-blue">
                <div class="stat-header">
                    <div class="stat-icon"><i class="fa-solid fa-house-chimney-window"></i></div>
                    <div class="stat-info">
                        <div class="stat-label">État de la Maison</div>
                        <div class="stat-sub">Progression collective</div>
                    </div>
                    @{
                        var allTasks = (IEnumerable<Bayti.Models.TaskInstance>)ViewBag.AllTasks ?? new List<Bayti.Models.TaskInstance>();
                        var allCompleted = allTasks.Count(t => t.Status == "Completed");
                        var allTotal = allTasks.Count();
                        var allProgress = allTotal > 0 ? (allCompleted * 100 / allTotal) : 0;
                    }
                    <div class="stat-perc">@allProgress%</div>
                </div>
                <div class="stat-progress">
                    <div class="stat-fill" style="width:@allProgress%; background: var(--blue);"></div>
                </div>
                <div class="stat-footer">@allCompleted sur @allTotal missions terminées</div>
            </div>
        }

        <!-- My Progress -->
        <div class="stat-card stat-card-coral">
            <div class="stat-header">
                <div class="stat-icon"><i class="fa-solid fa-broom"></i></div>
                <div class="stat-info">
                    <div class="stat-label">Mission Brillance</div>
                    <div class="stat-sub">Mes tâches personnelles</div>
                </div>
                <div class="stat-perc">@progress%</div>
            </div>
            <div class="stat-progress">
                <div class="stat-fill" style="width:@progress%; background: var(--coral);"></div>
            </div>
            <div class="stat-footer">@completedCount sur @totalCount tâches terminées</div>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">☕</div>
            <h3>Maison étincelante !</h3>
            <p>Aucune mission pour le moment. Profitez de votre café !</p>
        </div>
    }
    else
    {
        <div class="tasks-grid">
            @foreach (var item in Model.OrderBy(t => t.Status == "Completed").ThenBy(t => t.DueDate))
            {
                bool isTakenByOther = item.AssignedUserId != null && item.AssignedUserId != currentUserId;
                string cardClass = item.Status == "Completed" ? "is-done"
                                 : isTakenByOther ? "is-locked" : "";
                <div class="task-card @cardClass">
                    <div class="tc-icon">
                        @if (item.TaskTemplate.Category?.Icon?.StartsWith("fa-") == true) {
                            <i class="fa-solid @item.TaskTemplate.Category.Icon"></i>
                        } else {
                            <span>@(item.TaskTemplate.Category?.Icon ?? "✨")</span>
                        }
                    </div>
                    <div class="tc-body">
                        <div class="tc-top">
                            <h3 class="tc-title">@item.TaskTemplate.Title</h3>
                            <div class="tc-pts">+@item.TaskTemplate.Points ⭐</div>
                        </div>
                        <div class="tc-meta">
                            <span class="badge @(item.DueDate < DateTime.Now && item.Status != "Completed" ? "badge-red" : "badge-blue")">
                                <i class="fa-solid fa-clock"></i> @item.DueDate.ToString("HH:mm")
                            </span>
                            @if (item.TaskTemplate.Category != null) {
                                <span class="badge badge-mint">@item.TaskTemplate.Category.Name</span>
                            }
                        </div>
                    </div>
                    <div class="tc-action">
                        @if (item.Status == "Completed") {
                            <div class="done-badge"><i class="fa-solid fa-circle-check"></i> Fait !</div>
                        } else if (item.AssignedUserId != null && item.AssignedUserId != currentUserId) {
                            <!-- Taken by another user: locked -->
                            <div class="locked-badge">
                                <i class="fa-solid fa-lock"></i> Déjà pris
                            </div>
                        } else if (item.AssignedUserId == null) {
                            <form asp-action="Claim" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn-claim" title="S'attribuer cette tâche">
                                    <i class="fa-solid fa-hand-sparkles"></i> Choisir
                                </button>
                            </form>
                        } else {
                            <form asp-action="Complete" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn-complete">
                                    <i class="fa-solid fa-check"></i> Terminer
                                </button>
                            </form>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
.page-subtitle { font-size: 14px; color: var(--ink-3); margin-top: 4px; text-transform: capitalize; }
.dashboard-stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 16px; }
.stat-card { background: var(--surface); border: 1.5px solid var(--border); border-radius: 20px; padding: 20px; box-shadow: var(--shadow-xs); }
.stat-header { display: flex; align-items: center; gap: 14px; margin-bottom: 16px; }
.stat-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; }
.stat-card-blue .stat-icon { background: var(--blue-bg); color: var(--blue); }
.stat-card-coral .stat-icon { background: var(--coral-bg); color: var(--coral); }
.stat-info { flex: 1; }
.stat-label { font-weight: 800; font-size: 15px; color: var(--ink); }
.stat-sub { font-size: 11px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.5px; font-weight: 700; margin-top: 2px; }
.stat-perc { font-family: var(--font-display); font-size: 24px; font-weight: 900; color: var(--ink); }
.stat-card-blue .stat-perc { color: var(--blue); }
.stat-card-coral .stat-perc { color: var(--coral); }
.stat-progress { height: 8px; background: var(--bg-2); border-radius: 99px; overflow: hidden; margin-bottom: 10px; }
.stat-fill { height: 100%; border-radius: 99px; transition: width 1s cubic-bezier(0.34,1.56,0.64,1); }
.stat-footer { font-size: 12px; font-weight: 600; color: var(--ink-3); }

.tasks-grid { display: flex; flex-direction: column; gap: 12px; }
.task-card {
    display: flex; align-items: center; gap: 18px;
    padding: 18px 22px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 18px;
    transition: var(--t-spring);
    box-shadow: var(--shadow-xs);
}
.task-card:hover:not(.is-done):not(.is-locked) { transform: translateX(6px); border-color: var(--coral); box-shadow: var(--shadow-sm); }
.task-card.is-done { opacity: 0.55; background: var(--bg-2); }
.task-card.is-locked { opacity: 0.5; background: var(--bg-2); border-style: dashed; cursor: default; }

.tc-icon {
    width: 54px; height: 54px; border-radius: 16px;
    background: var(--coral-bg); color: var(--coral);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
    border: 1.5px solid rgba(255,107,107,0.15);
}
.is-done .tc-icon { background: var(--bg-3); color: var(--ink-4); border-color: var(--border); }
.tc-body { flex: 1; min-width: 0; }
.tc-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.tc-title { font-size: 16px; font-weight: 800; color: var(--ink); }
.is-done .tc-title { text-decoration: line-through; color: var(--ink-4); }
.tc-pts { font-family: var(--font-display); font-size: 15px; font-weight: 800; color: var(--coral); white-space: nowrap; }
.tc-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

.btn-complete {
    background: var(--grad-mint); color: white;
    border: none; padding: 10px 20px; border-radius: 12px;
    font-weight: 700; font-size: 13px; cursor: pointer;
    transition: var(--t-spring); display: flex; align-items: center; gap: 8px;
    white-space: nowrap;
}
.btn-complete:hover { transform: scale(1.06); box-shadow: var(--shadow-mint); }

.btn-claim {
    background: var(--surface); color: var(--coral);
    border: 2px solid var(--coral); padding: 8px 18px; border-radius: 12px;
    font-weight: 800; font-size: 13px; cursor: pointer;
    transition: var(--t-spring); display: flex; align-items: center; gap: 8px;
    white-space: nowrap;
}
.btn-claim:hover { background: var(--coral); color: white; transform: scale(1.06); box-shadow: var(--shadow-coral-sm); }

.done-badge { display: flex; align-items: center; gap: 6px; color: var(--green); font-weight: 800; font-size: 14px; white-space: nowrap; }
.locked-badge { display: flex; align-items: center; gap: 6px; color: var(--ink-4); font-weight: 700; font-size: 13px; white-space: nowrap; background: var(--bg-3); padding: 8px 14px; border-radius: 10px; border: 1px solid var(--border); }
</style>

@model IEnumerable<Bayti.Models.TaskInstance>
@{
    ViewData["Title"] = "Gérer les Affectations";
    var members = ViewBag.Members as IEnumerable<Bayti.Models.ApplicationUser>;
}

<div class="page-wrap">

    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
        <div>
            <h1 class="page-title">👑 Gérer les affectations</h1>
            <p class="page-subtitle">Mode Manuel : Distribuez les tâches du jour aux membres de votre tribu.</p>
        </div>
        <div style="display:flex; gap:12px; align-items:center;">
            <a asp-action="GenerateTestTasks" class="btn btn-coral" title="Générer les tâches d'aujourd'hui">
                <i class="fa-solid fa-rotate"></i> Générer
            </a>
            <a asp-action="Index" class="btn btn-ghost">
                <i class="fa-solid fa-arrow-left"></i> Retour aux tâches
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="empty-state">
            <div class="empty-state-icon">✅</div>
            <h3>Aucune tâche à assigner</h3>
            <p>Toutes les tâches du jour ont déjà été terminées !</p>
        </div>
    }
    else
    {
        <div class="tasks-grid">
            @foreach (var task in Model)
            {
                <div class="task-card">
                    <div class="tc-icon">
                        @if (task.TaskTemplate.Category?.Icon?.StartsWith("fa-") == true) {
                            <i class="fa-solid @task.TaskTemplate.Category.Icon"></i>
                        } else {
                            <span>@(task.TaskTemplate.Category?.Icon ?? "✨")</span>
                        }
                    </div>
                    <div class="tc-body">
                        <div class="tc-top">
                            <h3 class="tc-title">@task.TaskTemplate.Title</h3>
                            <div class="tc-pts">+@task.TaskTemplate.Points ⭐</div>
                        </div>
                        <div class="tc-meta">
                            <span class="badge badge-mint">@task.TaskTemplate.Category?.Name</span>
                            <span class="badge badge-blue"><i class="fa-solid fa-clock"></i> Avant 20h00</span>
                        </div>
                    </div>
                    <div class="tc-action" style="min-width: 250px;">
                        <form asp-action="AssignTask" method="post" style="display:flex; gap:8px; width:100%;">
                            <input type="hidden" name="taskId" value="@task.Id" />
                            <select name="assignedUserId" class="form-select flex-grow" style="background:var(--bg); border:1.5px solid var(--border); border-radius:12px; padding:10px 14px; font-family:var(--font-body); font-weight:700; color:var(--ink); flex:1;">
                                <option value="">-- Non assigné --</option>
                                @foreach (var member in members)
                                {
                                    <option value="@member.Id" selected="@(task.AssignedUserId == member.Id)">
                                        @member.FullName
                                    </option>
                                }
                            </select>
                            <button type="submit" class="btn-assign" title="Valider l'assignation">
                                <i class="fa-solid fa-check"></i>
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
.page-subtitle { font-size: 14px; color: var(--ink-3); margin-top: 4px; }

.tasks-grid { display: flex; flex-direction: column; gap: 12px; }
.task-card {
    display: flex; align-items: center; gap: 18px;
    padding: 18px 22px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 18px;
    transition: var(--t-spring);
    box-shadow: var(--shadow-xs);
    flex-wrap: wrap;
}
.task-card:hover { transform: translateX(6px); border-color: var(--coral); box-shadow: var(--shadow-sm); }

.tc-icon {
    width: 54px; height: 54px; border-radius: 16px;
    background: var(--coral-bg); color: var(--coral);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; flex-shrink: 0;
    border: 1.5px solid rgba(255,107,107,0.15);
}
.tc-body { flex: 1; min-width: 200px; }
.tc-top { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
.tc-title { font-size: 16px; font-weight: 800; color: var(--ink); }
.tc-pts { font-family: var(--font-display); font-size: 15px; font-weight: 800; color: var(--coral); white-space: nowrap; }
.tc-meta { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }

.btn-assign {
    background: var(--grad-coral); color: white;
    border: none; border-radius: 12px; width: 44px; height: 44px;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; cursor: pointer; transition: var(--t-spring);
    box-shadow: var(--shadow-coral-sm); flex-shrink: 0;
}
.btn-assign:hover { transform: scale(1.1); box-shadow: var(--shadow-coral); }
</style>

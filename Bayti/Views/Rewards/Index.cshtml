@using System.Security.Claims
@model IEnumerable<Bayti.Models.Reward>
@{
    ViewData["Title"] = "Boutique des Récompenses";
    var userPoints = (int)ViewBag.UserPoints;
    var isAdmin = User.FindFirst("IsAdmin")?.Value == "True";
}

<div class="page-wrap">

    <!-- Hero Points Bar -->
    <div class="shop-hero">
        <div class="shop-hero-inner">
            <div class="shop-hero-orb"></div>
            <div class="shop-hero-left">
                <div class="shop-hero-label">🎁 Boutique & Récompenses</div>
                <h1 class="shop-hero-title">Dépensez vos étoiles !</h1>
                <p class="shop-hero-sub">Échangez vos points gagnés contre des récompenses.</p>
            </div>
            <div class="shop-pts-badge">
                <div class="shop-pts-num">@userPoints</div>
                <div class="shop-pts-label">⭐ Points disponibles</div>
            </div>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null) {
        <div class="alert alert-success"><i class="fa-solid fa-gift"></i> @TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null) {
        <div class="alert alert-danger"><i class="fa-solid fa-triangle-exclamation"></i> @TempData["ErrorMessage"]</div>
    }

    <!-- Top bar -->
    <div style="display:flex; justify-content:flex-end; margin-bottom:24px;">
        @if (isAdmin) {
            <a asp-action="Create" class="btn btn-coral">
                <i class="fa-solid fa-plus"></i> Nouvelle récompense
            </a>
        }
    </div>

    @if (!Model.Any()) {
        <div class="empty-state">
            <div class="empty-state-icon">🏪</div>
            <h3>Boutique vide</h3>
            <p>L'admin va bientôt ajouter des cadeaux !</p>
        </div>
    } else {
        <div class="rewards-grid">
            @foreach (var reward in Model) {
                bool canAfford = userPoints >= reward.Price;
                <div class="reward-card @(canAfford ? "" : "cant-afford")">
                    @if (isAdmin) {
                        <div class="rw-admin">
                            <a asp-action="Edit" asp-route-id="@reward.Id" class="rw-admin-btn rw-edit"><i class="fa-solid fa-pen"></i></a>
                            <button type="button" class="rw-admin-btn rw-del" onclick="confirmDeleteReward(@reward.Id, '@reward.Name.Replace("'", "\\'")')"><i class="fa-solid fa-trash"></i></button>
                        </div>
                    }
                    <div class="rw-icon-wrap">
                        <span class="rw-emoji">@(string.IsNullOrEmpty(reward.Emoji) ? "🎁" : reward.Emoji)</span>
                        @if (reward.IsJoker) {
                            <div class="joker-tag">JOKER 🃏</div>
                        }
                    </div>
                    <h3 class="rw-name">@reward.Name</h3>
                    <p class="rw-desc">@reward.Description</p>
                    <div class="rw-footer">
                        <div class="rw-price @(canAfford ? "rw-price-ok" : "rw-price-no")">
                            ⭐ @reward.Price pts
                        </div>
                        <form asp-action="Buy" asp-route-id="@reward.Id" method="post"
                              onsubmit="return confirm('Acheter @reward.Name pour @reward.Price points ?')">
                            <button type="submit" class="rw-buy-btn" @(canAfford ? "" : "disabled")>
                                @(canAfford ? "Acheter 🛒" : "Points insuffisants")
                            </button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>

<form id="deleteRewardForm" asp-action="Delete" method="post" style="display:none;">
    <input type="hidden" name="id" id="deleteRewardId" />
</form>
<div id="dangerModal" class="modal-overlay" style="display:none;">
    <div class="modal-box">
        <div class="modal-icon" style="background:var(--red-bg);color:var(--red);"><i class="fa-solid fa-trash-can"></i></div>
        <h2 class="modal-title">Supprimer ?</h2>
        <p style="color:var(--ink-3);font-size:14px;">Voulez-vous vraiment supprimer <strong id="deleteRewardName"></strong> ?</p>
        <div class="modal-btns">
            <button type="button" class="btn btn-ghost" onclick="closeDangerModal()">Annuler</button>
            <button type="button" id="confirmDeleteBtn" class="btn btn-danger">Supprimer</button>
        </div>
    </div>
</div>

<style>
.shop-hero { background: linear-gradient(135deg, #1A1D2E 0%, #2D3158 100%); border-radius: 24px; margin-bottom: 28px; padding: 36px 44px; position: relative; overflow: hidden; box-shadow: 0 16px 48px rgba(26,29,46,0.25); }
.shop-hero-orb { position: absolute; width: 350px; height: 350px; background: radial-gradient(circle, rgba(255,107,107,0.18) 0%, transparent 70%); top: -120px; right: -80px; border-radius: 50%; }
.shop-hero-inner { display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1; }
.shop-hero-label { font-size: 12px; font-weight: 700; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 10px; }
.shop-hero-title { font-family: var(--font-display); font-size: 36px; font-weight: 900; color: white; letter-spacing: -0.5px; margin-bottom: 8px; }
.shop-hero-sub { font-size: 15px; color: rgba(255,255,255,0.55); }
.shop-pts-badge { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); backdrop-filter: blur(10px); border-radius: 20px; padding: 24px 32px; text-align: center; }
.shop-pts-num { font-family: var(--font-display); font-size: 44px; font-weight: 900; color: #FFD700; line-height: 1; }
.shop-pts-label { font-size: 13px; color: rgba(255,255,255,0.55); margin-top: 6px; font-weight: 600; }

.rewards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 22px; }
.reward-card {
    background: var(--surface); border: 1.5px solid var(--border); border-radius: 24px;
    padding: 28px; display: flex; flex-direction: column;
    transition: var(--t-spring); position: relative; box-shadow: var(--shadow-xs);
}
.reward-card:not(.cant-afford):hover { transform: translateY(-8px) scale(1.02); border-color: var(--coral); box-shadow: 0 20px 48px rgba(255,107,107,0.18); }
.reward-card.cant-afford { opacity: 0.6; filter: grayscale(0.3); }

.rw-admin { position: absolute; top: 16px; right: 16px; display: flex; gap: 8px; opacity: 0; transition: var(--t-fast); }
.reward-card:hover .rw-admin { opacity: 1; }
.rw-admin-btn { width: 32px; height: 32px; border-radius: 10px; display: flex; align-items: center; justify-content: center; border: none; cursor: pointer; font-size: 13px; transition: var(--t-fast); }
.rw-edit { background: var(--blue-bg); color: var(--blue); }
.rw-del  { background: var(--red-bg);  color: var(--red);  }
.rw-admin-btn:hover { transform: scale(1.15); }

.rw-icon-wrap { width: 80px; height: 80px; background: linear-gradient(135deg, #FFF9EC, #FEF0C7); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin-bottom: 20px; position: relative; box-shadow: 0 8px 20px rgba(245,166,35,0.2); }
.rw-emoji { font-size: 38px; }
.joker-tag { position: absolute; top: -8px; right: -24px; background: var(--red); color: white; font-size: 9px; font-weight: 900; padding: 3px 8px; border-radius: 10px; transform: rotate(5deg); letter-spacing: 0.5px; }

.rw-name { font-family: var(--font-display); font-size: 19px; font-weight: 800; color: var(--ink); margin-bottom: 8px; }
.rw-desc { font-size: 13px; color: var(--ink-3); line-height: 1.5; flex: 1; margin-bottom: 20px; }
.rw-footer { display: flex; flex-direction: column; gap: 10px; }
.rw-price { text-align: center; font-weight: 800; font-size: 15px; padding: 8px 14px; border-radius: 12px; }
.rw-price-ok { background: #FFFBEC; color: #B45309; }
.rw-price-no { background: var(--bg-2); color: var(--ink-4); }
.rw-buy-btn { width: 100%; padding: 14px; border-radius: 16px; border: none; font-family: var(--font-display); font-size: 15px; font-weight: 800; cursor: pointer; transition: var(--t-spring); }
.rw-buy-btn:not([disabled]) { background: var(--grad-warm); color: white; box-shadow: 0 6px 20px rgba(245,166,35,0.3); }
.rw-buy-btn:not([disabled]):hover { transform: translateY(-3px); box-shadow: 0 12px 30px rgba(245,166,35,0.4); }
.rw-buy-btn[disabled] { background: var(--bg-2); color: var(--ink-4); cursor: not-allowed; }

/* Modal */
.modal-overlay { position: fixed; inset: 0; background: rgba(26,29,46,0.65); display: flex; align-items: center; justify-content: center; z-index: 1000; backdrop-filter: blur(6px); }
.modal-box { background: var(--surface); border-radius: 28px; padding: 40px; max-width: 400px; width: 90%; text-align: center; box-shadow: var(--shadow-lg); }
.modal-icon { width: 72px; height: 72px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 28px; margin: 0 auto 20px; }
.modal-title { font-family: var(--font-display); font-size: 22px; font-weight: 900; color: var(--ink); margin-bottom: 10px; }
.modal-btns { display: flex; gap: 12px; margin-top: 24px; }
.modal-btns .btn { flex: 1; justify-content: center; }
</style>

<script>
function confirmDeleteReward(id, name) {
    document.getElementById('deleteRewardId').value = id;
    document.getElementById('deleteRewardName').textContent = name;
    document.getElementById('dangerModal').style.display = 'flex';
}
function closeDangerModal() { document.getElementById('dangerModal').style.display = 'none'; }
document.getElementById('confirmDeleteBtn').addEventListener('click', () => document.getElementById('deleteRewardForm').submit());
window.addEventListener('click', (e) => { if (e.target.id === 'dangerModal') closeDangerModal(); });
</script>

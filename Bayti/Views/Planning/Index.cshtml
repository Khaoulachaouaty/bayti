@model Dictionary<DateTime, List<Bayti.Models.TaskTemplate>>
@{
    ViewData["Title"] = "Planning des missions";
    var startOfWeek = (DateTime)ViewBag.StartOfWeek;
    var endOfWeek = startOfWeek.AddDays(6);
    var culture = new System.Globalization.CultureInfo("fr-FR");
    var prevWeek = startOfWeek.AddDays(-7).ToString("yyyy-MM-dd");
    var nextWeek = startOfWeek.AddDays(7).ToString("yyyy-MM-dd");
    string[] dayColors = { "coral", "mint", "amber", "blue", "purple", "sky", "green" };
}

<div class="page-wrap">

    <!-- Header -->
    <div class="page-header" style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:16px;">
        <div>
            <h1 class="page-title">📅 Planning des missions</h1>
            <p class="page-subtitle">Du @startOfWeek.ToString("dd MMMM", culture) au @endOfWeek.ToString("dd MMMM yyyy", culture)</p>
        </div>
        <div class="plan-nav">
            <a asp-action="Index" asp-route-date="@prevWeek" class="plan-nav-btn" title="Semaine précédente">
                <i class="fa-solid fa-chevron-left"></i>
            </a>
            <a asp-action="Index" class="plan-nav-btn plan-today">Aujourd'hui</a>
            <a asp-action="Index" asp-route-date="@nextWeek" class="plan-nav-btn" title="Semaine suivante">
                <i class="fa-solid fa-chevron-right"></i>
            </a>
        </div>
    </div>

    <div class="planning-grid">
        @{ int di = 0; }
        @foreach (var day in Model)
        {
            var isToday = day.Key.Date == DateTime.Today;
            var color = dayColors[di % dayColors.Length];
            <div class="plan-col @(isToday ? "is-today" : "") plan-col-@color">
                <div class="plan-day-header">
                    <div class="plan-day-name">@culture.DateTimeFormat.GetAbbreviatedDayName(day.Key.DayOfWeek)</div>
                    <div class="plan-day-num @(isToday ? "today-num" : "")">@day.Key.Day</div>
                    <div class="plan-day-count">@day.Value.Count tâche@(day.Value.Count > 1 ? "s" : "")</div>
                </div>
                <div class="plan-tasks">
                    @if (!day.Value.Any())
                    {
                        <div class="plan-empty">🛁</div>
                    }
                    else
                    {
                        foreach (var task in day.Value)
                        {
                            <div class="plan-task">
                                <div class="plan-task-icon">
                                    @if (task.Category?.Icon?.StartsWith("fa-") == true) {
                                        <i class="fa-solid @task.Category.Icon"></i>
                                    } else {
                                        <span>@(task.Category?.Icon ?? "✨")</span>
                                    }
                                </div>
                                <div class="plan-task-info">
                                    <div class="plan-task-title" title="@task.Title">@task.Title</div>
                                    <div class="plan-task-pts">@task.Points ⭐</div>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>
            di++;
        }
    </div>

</div>

<style>
.page-subtitle { font-size: 14px; color: var(--ink-3); margin-top: 4px; }

.plan-nav { display: flex; align-items: center; gap: 8px; }
.plan-nav-btn {
    padding: 10px 16px; border-radius: 12px; font-size: 14px; font-weight: 700;
    background: var(--surface); border: 1.5px solid var(--border); color: var(--ink-2);
    text-decoration: none; transition: var(--t-spring); display: inline-flex; align-items: center; gap: 6px;
}
.plan-nav-btn:hover { background: var(--coral-bg); border-color: var(--coral); color: var(--coral); transform: translateY(-2px); }
.plan-today { padding: 10px 20px; }

.planning-grid { display: grid; grid-template-columns: repeat(7, 1fr); gap: 14px; align-items: start; }

.plan-col {
    border-radius: 20px; padding: 16px 12px;
    display: flex; flex-direction: column; min-height: 380px;
    border: 1.5px solid var(--border);
    background: var(--surface);
    box-shadow: var(--shadow-xs);
    transition: var(--t-spring);
}
.plan-col:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
.plan-col.is-today {
    border-color: var(--coral) !important;
    background: linear-gradient(180deg, #FFF5F5 0%, #FFFFFF 100%) !important;
    box-shadow: 0 8px 28px rgba(255,107,107,0.18) !important;
}

/* Day color accents */
.plan-col-coral .plan-day-header { background: linear-gradient(135deg, var(--coral-bg), #FFE8E8); }
.plan-col-mint  .plan-day-header { background: linear-gradient(135deg, var(--mint-bg), #C8F5EE); }
.plan-col-amber .plan-day-header { background: linear-gradient(135deg, var(--amber-bg), #FEE8C0); }
.plan-col-blue  .plan-day-header { background: linear-gradient(135deg, var(--blue-bg), #D6E8FA); }
.plan-col-purple.plan-day-header { background: linear-gradient(135deg, var(--purple-bg), #E4D8FC); }
.plan-col-sky   .plan-day-header { background: linear-gradient(135deg, var(--sky-bg), #C8EFED); }
.plan-col-green .plan-day-header { background: linear-gradient(135deg, var(--green-bg), #C8F0DC); }
.is-today .plan-day-header { background: linear-gradient(135deg, var(--coral-bg), #FFDEDE) !important; }

.plan-day-header {
    border-radius: 14px; padding: 14px 10px; margin-bottom: 14px; text-align: center;
}
.plan-day-name { font-size: 10px; font-weight: 800; text-transform: uppercase; letter-spacing: 1.5px; color: var(--ink-3); margin-bottom: 4px; }
.is-today .plan-day-name { color: var(--coral); }
.plan-day-num { font-family: var(--font-display); font-size: 30px; font-weight: 900; color: var(--ink); line-height: 1.1; }
.today-num { color: var(--coral); }
.plan-day-count { font-size: 10px; color: var(--ink-4); font-weight: 600; margin-top: 4px; }

.plan-tasks { display: flex; flex-direction: column; gap: 8px; flex: 1; }
.plan-empty { text-align: center; padding: 40px 0; font-size: 28px; opacity: 0.25; }

.plan-task {
    display: flex; align-items: center; gap: 8px;
    padding: 9px 10px; border-radius: 12px;
    background: var(--bg); border: 1px solid var(--border);
    transition: var(--t-fast);
}
.plan-task:hover { background: var(--coral-bg); border-color: rgba(255,107,107,0.2); transform: scale(1.02); }
.is-today .plan-task { background: white; border-color: rgba(255,107,107,0.15); }
.plan-task-icon { width: 30px; height: 30px; border-radius: 9px; background: var(--surface); display: flex; align-items: center; justify-content: center; font-size: 14px; color: var(--coral); flex-shrink: 0; border: 1px solid var(--border); }
.plan-task-title { font-size: 12px; font-weight: 700; color: var(--ink); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.plan-task-pts { font-size: 10px; font-weight: 700; color: var(--ink-4); margin-top: 2px; }

@@media (max-width: 1100px) { .planning-grid { grid-template-columns: repeat(4, 1fr); } }
@@media (max-width: 700px)  { .planning-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
